# Database
DATABASE_URL=postgresql://appstrate:appstrate@localhost:5432/appstrate

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3010
TRUSTED_ORIGINS=http://localhost:3010,http://localhost:5173

# Connection Manager
CONNECTION_ENCRYPTION_KEY=<base64-256bit>   # openssl rand -base64 32
OAUTH_CALLBACK_URL=http://localhost:3010/auth/callback

# System providers (JSON array) — built-in providers with inline OAuth credentials
# If not set, no built-in providers are loaded (empty map)
# SYSTEM_PROVIDERS='[{"id":"google-mail","displayName":"Gmail","authMode":"oauth2","clientId":"...","clientSecret":"...","authorizationUrl":"https://accounts.google.com/o/oauth2/v2/auth","tokenUrl":"https://oauth2.googleapis.com/token","authorizedUris":["https://gmail.googleapis.com/*"]}]'

# Built-in resources (flows, skills, extensions, providers.json)
# If not set, no built-in resources are loaded (only SYSTEM_PROVIDERS env var)
DATA_DIR=./data

# Runtime storage (flow packages, execution files, library packages)
STORAGE_DIR=./storage

# Platform
PORT=3010
DOCKER_SOCKET=/var/run/docker.sock

# Execution Adapter: "pi" (default)
# EXECUTION_ADAPTER=pi

# Pi Adapter config
LLM_PROVIDER=anthropic
LLM_MODEL_ID=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Production
# POSTGRES_PASSWORD=changeme
