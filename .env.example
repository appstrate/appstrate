# LLM Configuration
LLM_MODEL=claude-sonnet-4-5-20250929

# Supabase (cloud or self-hosted)
SUPABASE_URL=http://localhost:8000          # or https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...                    # Public key (frontend + backend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # Secret key (backend only)

# Frontend Supabase (Vite env vars)
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=eyJ...

# Connection Manager
CONNECTION_ENCRYPTION_KEY=<base64-256bit>   # openssl rand -base64 32
OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# System providers (JSON array) — built-in providers with inline OAuth credentials
# If not set, no built-in providers are loaded (empty map)
# SYSTEM_PROVIDERS='[{"id":"google-mail","displayName":"Gmail","authMode":"oauth2","clientId":"...","clientSecret":"...","authorizationUrl":"https://accounts.google.com/o/oauth2/v2/auth","tokenUrl":"https://oauth2.googleapis.com/token","authorizedUris":["https://gmail.googleapis.com/*"]}]'

# Platform
PORT=3000
DOCKER_SOCKET=/var/run/docker.sock

# Execution Adapter: "pi" (default)
# EXECUTION_ADAPTER=pi

# Pi Adapter config
LLM_PROVIDER=anthropic
LLM_MODEL_ID=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Production
# POSTGRES_PASSWORD=changeme
