# LLM Configuration
LLM_MODEL=claude-sonnet-4-5-20250929
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...  # Run `claude setup-token` to generate

# Supabase (cloud or self-hosted)
SUPABASE_URL=http://localhost:8000          # or https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...                    # Public key (frontend + backend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # Secret key (backend only)

# Frontend Supabase (Vite env vars)
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=eyJ...

# Nango (OAuth)
NANGO_URL=http://localhost:3003
NANGO_SECRET_KEY=<uuid-v4>
NANGO_ENCRYPTION_KEY=<base64-256bit-key>  # openssl rand -base64 32

# Platform
PORT=3000
DOCKER_SOCKET=/var/run/docker.sock

# Production (docker-compose.prod.yml)
# POSTGRES_PASSWORD=changeme           # Required for prod compose
# NANGO_PUBLIC_URL=https://nango.yourdomain.com  # Public Nango URL (OAuth callbacks)
