# ─── Appstrate — Development Environment ───────────────────────
#
# This file works AS-IS for Tier 0 (zero-install, no Docker).
# Just run: cp .env.example .env && bun run dev
#
# Appstrate uses progressive infrastructure — uncomment sections
# below to scale up from Tier 0 to Tier 3.
#
# Authoritative validation: packages/env/src/index.ts (Zod schema)
# ────────────────────────────────────────────────────────────────

# ─── Modules (comma-separated, empty = OSS mode) ─────────────
# APPSTRATE_MODULES=@appstrate/cloud

# ─── Required (all tiers) ─────────────────────────────────────

APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
PORT=3000

# Auth — ⚠️ DEV ONLY — regenerate for production: openssl rand -hex 32
BETTER_AUTH_SECRET=appstrate-dev-auth-secret-do-not-use-in-production
RUN_TOKEN_SECRET=appstrate-dev-token-secret-do-not-use-in-production

# Credential encryption — ⚠️ DEV ONLY — regenerate for production: openssl rand -base64 32
CONNECTION_ENCRYPTION_KEY=jChGxOEG1YjCtrkrTYhO7FFdIKaHpe/j1PBY/LqID6s=

# ─── Tier 1+ (PostgreSQL) ────────────────────────────────────
# Uncomment to use an external PostgreSQL instead of PGlite (embedded).
# Start with: bun run docker:dev:minimal

# DATABASE_URL=postgresql://appstrate:appstrate@localhost:5423/appstrate
# POSTGRES_USER=appstrate        # used by docker-compose
# POSTGRES_PASSWORD=appstrate    # used by docker-compose

# ─── Tier 2+ (Redis) ─────────────────────────────────────────
# Uncomment for persistent scheduling and multi-instance support.
# Start with: bun run docker:dev:standard

# REDIS_URL=redis://localhost:6379

# ─── Tier 3 (S3 + Docker execution) ──────────────────────────
# Uncomment for S3 storage and Docker-isolated agent execution.
# Start with: bun run docker:dev

# S3_BUCKET=appstrate
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# MINIO_ROOT_USER=minioadmin     # used by docker-compose
# MINIO_ROOT_PASSWORD=minioadmin
# RUN_ADAPTER=docker
# SIDECAR_POOL_SIZE=2
# DOCKER_SOCKET=/var/run/docker.sock

# ─── Optional (all tiers) ────────────────────────────────────

# Filesystem storage path (Tier 0-2, when S3_BUCKET is absent)
# FS_STORAGE_PATH=./data/storage

# PGlite data directory (Tier 0, when DATABASE_URL is absent)
# PGLITE_DATA_DIR=./data/pglite

# Cookie domain (cross-subdomain auth)
# COOKIE_DOMAIN=.appstrate.com

# Runtime images (override for GHCR / custom registries)
# PI_IMAGE=ghcr.io/appstrate/appstrate-pi:latest
# SIDECAR_IMAGE=ghcr.io/appstrate/appstrate-sidecar:latest

# Platform API URL (how sidecar reaches host — fallback computed at runtime)
# PLATFORM_API_URL=http://localhost:3000

# Outbound proxy for execution containers
# PROXY_URL=http://user:pass@proxy.example.com:22225

# Logging (default: info)
# LOG_LEVEL=info

# System provider keys (JSON array) — pre-configured LLM provider credentials
# SYSTEM_PROVIDER_KEYS='[{"id":"anthropic","label":"Anthropic","api":"anthropic-messages","baseUrl":"https://api.anthropic.com","apiKey":"sk-ant-...","models":[{"modelId":"claude-sonnet-4-6","label":"Claude Sonnet 4.6","isDefault":true}]}]'

# System proxies (JSON array)
# SYSTEM_PROXIES='[{"id":"my-proxy","label":"Residential","url":"http://user:pass@host:port","isDefault":true}]'

# ─── Optional: Social Login ──────────────────────────────────

# Google Sign-In (requires Google OAuth App)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub Sign-In (requires GitHub OAuth App — not GitHub App)
# GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ─── Optional: Email Verification ────────────────────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com
