# LLM Configuration
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5-20250929

# Database
DATABASE_URL=postgres://openflows:openflows@localhost:5432/openflows

# Nango (OAuth)
NANGO_URL=http://localhost:3003
NANGO_SECRET_KEY=<uuid-v4>
NANGO_ENCRYPTION_KEY=<base64-256bit-key>  # openssl rand -base64 32

# Platform
PORT=3000
DOCKER_SOCKET=/var/run/docker.sock
FLOW_TIMEOUT=300000
MAX_CONCURRENT_CONTAINERS=3

# Execution adapter: docker | claude-code
EXECUTION_ADAPTER=docker
# CLAUDE_CLI_PATH=/path/to/claude                    # Only needed for claude-code adapter
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...           # Run `claude setup-token` to generate (uses Claude subscription)

# Auth (MVP: single static token)
AUTH_TOKEN=change-me-to-a-random-secret
