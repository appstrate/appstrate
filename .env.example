# Database
DATABASE_URL=postgresql://appstrate:appstrate@localhost:5432/appstrate

# App
APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Execution Token
EXECUTION_TOKEN_SECRET=change-me-to-a-random-secret

# Connection Manager
CONNECTION_ENCRYPTION_KEY=<base64-256bit>   # openssl rand -base64 32

# System proxies (JSON array) — pre-configured proxy definitions
# SYSTEM_PROXIES='[{"id":"my-proxy","label":"Decodo Residential","url":"http://user:pass@gate.decodo.com:10002","isDefault":true}]'

# S3 storage (required — use MinIO for local dev, see docker-compose.override.example.yml)
S3_BUCKET=appstrate
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000   # MinIO local endpoint (remove for real AWS S3)
AWS_ACCESS_KEY_ID=minioadmin        # MinIO credentials (use IAM roles for real AWS)
AWS_SECRET_ACCESS_KEY=minioadmin

# Redis (required — scheduling, rate limiting, cancel signaling, OAuth state)
REDIS_URL=redis://localhost:6379

# Platform
PORT=3000
DOCKER_SOCKET=/var/run/docker.sock
# PLATFORM_API_URL=http://localhost:3000   # How sidecar reaches host (fallback: http://host.docker.internal:{PORT})

# Execution Adapter: "pi" (default)
# EXECUTION_ADAPTER=pi

# Sidecar pool size (0 = disabled, default: 2)
# SIDECAR_POOL_SIZE=2

# System provider keys (JSON array) — pre-configured LLM provider credentials with models
# Each entry: { id, label, api, baseUrl, apiKey, models: [{ modelId, label, isDefault? }] }
# SYSTEM_PROVIDER_KEYS='[{"id":"anthropic-prod","label":"Anthropic","api":"anthropic-messages","baseUrl":"https://api.anthropic.com","apiKey":"sk-ant-...","models":[{"modelId":"claude-sonnet-4-6","label":"Claude Sonnet 4.6","isDefault":true}]}]'

# Outbound proxy for execution containers (residential/ISP proxy)
# Format: http://user:password@host:port
# PROXY_URL=http://user:pass@proxy.example.com:22225

# Logging (default: info)
# LOG_LEVEL=info
