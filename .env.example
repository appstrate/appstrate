# ─── Appstrate — Development Environment ───────────────────────
#
# This file works AS-IS for Tier 0 (zero-install, no Docker).
# Just run: cp .env.example .env && bun run dev
#
# Appstrate uses progressive infrastructure — uncomment sections
# below to scale up from Tier 0 to Tier 3.
#
# Authoritative validation: packages/env/src/index.ts (Zod schema)
# ────────────────────────────────────────────────────────────────

# ─── Modules (comma-separated specifiers) ────────────────────
# Modules loaded by default (OSS, API-key only):
#   - oidc            — OAuth 2.1 / OIDC identity provider for embedding apps
#   - webhooks        — Standard Webhooks event delivery for agent runs
#   - mcp             — platform MCP server (agents drive the platform)
#   - core-providers  — API-key model providers (OpenAI, Anthropic, OpenAI-compatible)
# Append external module specifiers to extend, or remove an id to disable.
#
# OPT-IN subscription providers (NOT loaded by default):
#   - @appstrate/module-codex       — ChatGPT/Codex OAuth provider (workspace package)
#   - @appstrate/module-claude-code — Claude Pro/Max/Team OAuth provider (workspace package)
# Powering a product with a PERSONAL ChatGPT/Claude subscription is an
# operator-owned grey-zone: Anthropic's Agent SDK docs permit third-party
# claude.ai-login products only with prior approval, and the policy flipped
# repeatedly in 2026 (OpenAI's stance is undocumented). The OSS default ships
# neither — append them deliberately, having reviewed the upstream ToS. See
# docs/architecture/SUBSCRIPTION_COMPLIANCE.md.
#   MODULES=oidc,webhooks,mcp,core-providers,@appstrate/module-chat,@appstrate/module-codex,@appstrate/module-claude-code
MODULES=oidc,webhooks,mcp,core-providers,@appstrate/module-chat

# ─── Required (all tiers) ─────────────────────────────────────

APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
PORT=3000

# Trust proxy — controls how `lib/client-ip.ts` reads X-Forwarded-For.
#
# CRITICAL: must match your deployment topology exactly. X-Forwarded-For
# is used by rate limiters (including the OIDC /oauth2/token brute-force
# limiter) and audit logs — a misconfigured TRUST_PROXY lets an attacker
# inject a spoofed client IP via the XFF header and bypass per-IP limits.
#
#   false  — direct exposure, XFF ignored (default, safest for dev/tier-0)
#   true   — 1 trusted reverse proxy in front of the app (== "1")
#   N      — N trusted proxy hops (e.g. "2" behind a CDN + LB)
#
# Set this ONLY if every hop between the public internet and the app is
# a proxy YOU control that strips untrusted XFF from incoming requests.
# If unsure, leave "false" — the rate limiters will fall back to the
# socket peer address, which cannot be spoofed.
# TRUST_PROXY=false

# Auth — ⚠️ DEV ONLY — regenerate for production: openssl rand -hex 32
BETTER_AUTH_SECRET=appstrate-dev-auth-secret-do-not-use-in-production
RUN_TOKEN_SECRET=appstrate-dev-token-secret-do-not-use-in-production
UPLOAD_SIGNING_SECRET=appstrate-dev-upload-secret-do-not-use-in-production
# Hosted-connect-portal session tokens (issue #769). Required — signs the
# short-lived tokens behind the integration "Connect" button (issue #905).
# Each comma-separated key ≥16 chars.
CONNECT_SESSION_SECRET=appstrate-dev-connect-secret-do-not-use-in-production
# CONNECT_SESSION_TTL_MS=600000

# Credential encryption — ⚠️ DEV ONLY — regenerate for production: openssl rand -base64 32
CONNECTION_ENCRYPTION_KEY=jChGxOEG1YjCtrkrTYhO7FFdIKaHpe/j1PBY/LqID6s=
# Active key id embedded in newly-encrypted credential blobs (v1 envelope).
# Default "k1". Change only when promoting a freshly-rotated key — see
# packages/connect/README.md for the rotation playbook.
# CONNECTION_ENCRYPTION_KEY_ID=k1
# Retired keys held for decrypt-only during a rotation window.
# JSON map: { "old_kid": "<base64 32-byte key>" }. Empty by default.
# CONNECTION_ENCRYPTION_KEYS={}

# ─── Tier 1+ (PostgreSQL) ────────────────────────────────────
# Uncomment to use an external PostgreSQL instead of PGlite (embedded).
# Start with: bun run docker:dev:minimal

# DATABASE_URL=postgresql://appstrate:appstrate@localhost:5423/appstrate
# POSTGRES_USER=appstrate        # used by docker-compose
# POSTGRES_PASSWORD=appstrate    # used by docker-compose

# ─── Tier 2+ (Redis) ─────────────────────────────────────────
# Uncomment for persistent scheduling and multi-instance support.
# Start with: bun run docker:dev:standard

# REDIS_URL=redis://localhost:6379

# ─── Tier 3 (S3 + Docker execution) ──────────────────────────
# Uncomment for S3 storage and Docker-isolated agent execution.
# Start with: bun run docker:dev

# S3_BUCKET=appstrate
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# MINIO_ROOT_USER=minioadmin     # used by docker-compose
# MINIO_ROOT_PASSWORD=minioadmin
# RUN_ADAPTER=docker
# SIDECAR_POOL_SIZE=2
# DOCKER_SOCKET=/var/run/docker.sock

# ─── Optional (all tiers) ────────────────────────────────────

# Filesystem storage path (Tier 0-2, when S3_BUCKET is absent)
# FS_STORAGE_PATH=./data/storage

# PGlite data directory (Tier 0, when DATABASE_URL is absent)
# PGLITE_DATA_DIR=./data/pglite

# Cookie domain (cross-subdomain auth)
# COOKIE_DOMAIN=.appstrate.com

# Runtime images (override for GHCR / custom registries)
# PI_IMAGE=ghcr.io/appstrate/appstrate-pi:latest
# SIDECAR_IMAGE=ghcr.io/appstrate/appstrate-sidecar:latest
# Per-integration MCP runner images. Forwarded to the sidecar, which spawns
# one runner container per local AFPS integration (server.type). Absent =>
# bare ":latest" default, resolvable only on a host that ran
# `bun run docker:build:runners`. Set to GHCR refs for self-hosted/prod.
# RUNNER_IMAGE_NODE=ghcr.io/appstrate/appstrate-mcp-runner-node:latest
# RUNNER_IMAGE_PYTHON=ghcr.io/appstrate/appstrate-mcp-runner-python:latest
# RUNNER_IMAGE_BUN=ghcr.io/appstrate/appstrate-mcp-runner-bun:latest
# RUNNER_IMAGE_UV=ghcr.io/appstrate/appstrate-mcp-runner-uv:latest
# RUNNER_IMAGE_BINARY=ghcr.io/appstrate/appstrate-mcp-runner-binary:latest

# Platform API URL (how sidecar reaches host — fallback computed at runtime)
# PLATFORM_API_URL=http://localhost:3000

# Outbound proxy for execution containers
# PROXY_URL=http://user:pass@proxy.example.com:22225

# Logging (default: info)
# LOG_LEVEL=info

# System provider keys (JSON array) — pre-configured LLM provider credentials.
# `providerId` must match a registered ModelProviderDefinition (anthropic,
# openai, openai-compatible, cerebras, google-ai, groq, mistral, openrouter,
# xai). `apiShape`, the default base URL, the provider key label, and per-
# model labels are all resolved from the registry + vendored pricing catalog
# — don't repeat them here. Pass `label` explicitly only when the registry
# `displayName` (provider key) or catalog label (model) doesn't fit. For
# `openai-compatible`, set `baseUrlOverride` to point at a custom endpoint
# (vLLM, Ollama, LiteLLM, …).
#
# Model alias (LLM-gateway alias pattern, issue #727): a nested model entry MAY
# set "aliased": true to expose it under an Appstrate-branded vanity id while
# the real backing model stays hidden server-side. The entry `id` is the public
# alias; the real upstream id is `modelId`. An aliased entry MUST carry an
# explicit "label" (a derived one would name the backing) and use a body-`model`
# protocol (anthropic-messages, openai-completions, openai-responses,
# openai-codex-responses, mistral-conversations) — google/azure/bedrock put the
# model id in the URL and are rejected. Misconfigured aliases are skipped
# (logged) at boot. See docs/architecture/MODEL_ALIASES.md.
# SYSTEM_PROVIDER_KEYS='[{"id":"anthropic","providerId":"anthropic","apiKey":"sk-ant-...","models":[{"modelId":"claude-sonnet-4-6","isDefault":true}]}]'
# Aliased example (real backing `deepseek-chat` hidden behind `appstrate-medium`):
# SYSTEM_PROVIDER_KEYS='[{"id":"appstrate-deepseek","providerId":"openai-compatible","apiKey":"sk-...","baseUrlOverride":"https://api.deepseek.com","models":[{"id":"appstrate-medium","modelId":"deepseek-chat","label":"Appstrate Medium","aliased":true}]}]'

# Featured-models picker exclusions (comma-separated model ids). Drops ids from
# the weekly featured list generated by scripts/refresh-pricing-catalog.ts. Use
# it to hide a model-alias BACKING so the real id never surfaces in the picker.
# System-key aliased backings are excluded automatically; DB-row alias backings
# must be listed here. Read directly via process.env (not in the Zod env schema).
# FEATURED_MODELS_EXCLUDE=deepseek-chat,some-other-backing

# System proxies (JSON array)
# SYSTEM_PROXIES='[{"id":"my-proxy","label":"Residential","url":"http://user:pass@host:port","isDefault":true}]'

# System integrations (JSON array) — integrations the deployment OFFERS out of
# the box. Listing an integration here makes it auto-active (on by default) until
# an org explicitly opts out. Each entry MAY ship one or more shared OAuth clients
# (a client_id/secret the platform provides for an auth, e.g. the verified
# Appstrate Google app) so every org connects without registering its own OAuth
# app — or NO clients, for remote MCP integrations that use Dynamic Client
# Registration (no static client_id; the client is provisioned on first connect).
# An org that registers its own per-application client overrides the system one;
# the minting client is pinned per connection so refresh resolves the right
# credentials. Per client, `client_secret` is optional (empty for public clients).
# NOTE (shared quota): a system client funnels EVERY org's API calls through one
# upstream project quota (e.g. Google's per-project Gmail quota), so a noisy org
# can degrade others. For quota-strict providers prefer per-org BYO-app, or only
# enable a system client behind per-user quota partitioning (follow-up: quotaUser).
# SYSTEM_INTEGRATIONS='[{"id":"@appstrate/gmail","clients":[{"id":"gmail-system","auth_key":"primary","client_id":"...apps.googleusercontent.com","client_secret":"..."}]},{"id":"@appstrate/notion-mcp"}]'

# ─── Run limits (platform + inline) ──────────────────────────

# Platform-wide run limits — applied to EVERY run (classic + inline + scheduled).
# JSON object; unset keys use the defaults shown. Validated strictly at boot
# (apps/api/src/services/run-limits.ts) — typos fail-fast.
#   timeout_ceiling_seconds    — hard cap on manifest.timeout (default: 1800)
#   per_org_global_rate_per_min — per-org run creation rate (default: 200)
#   max_concurrent_per_org     — max in-flight runs per org (default: 50)
# PLATFORM_RUN_LIMITS='{"timeout_ceiling_seconds":1800,"per_org_global_rate_per_min":200,"max_concurrent_per_org":50}'

# Inline-run caps — applied on top of PLATFORM_RUN_LIMITS for POST /api/runs/inline.
# Validated strictly at boot. Full spec: docs/specs/INLINE_RUNS.md §7.
#   rate_per_min         — per-user rate for /runs/inline + /runs/inline/validate (default: 60)
#   manifest_bytes       — max manifest size in UTF-8 bytes (default: 65536)
#   prompt_bytes         — max prompt size in UTF-8 bytes (default: 200000)
#   max_skills           — max entries in dependencies.skills (default: 20)
#   retention_days       — days before shadow manifest/prompt are NULLed by compaction (default: 30)
# INLINE_RUN_LIMITS='{"rate_per_min":60,"manifest_bytes":65536,"prompt_bytes":200000,"max_skills":20,"retention_days":30}'

# LLM proxy limits — caps on /api/llm-proxy/* (used by remote runners that
# delegate model calls back through the platform). Validated strictly at boot
# (apps/api/src/services/proxy-limits.ts) — typos fail-fast.
#   rate_per_min       — per-principal call rate (default: 60)
#   max_request_bytes  — max upstream LLM request body size (default: 10485760 / 10 MiB)
# LLM_PROXY_LIMITS='{"rate_per_min":60,"max_request_bytes":10485760}'

# Credential proxy limits — caps on /api/credential-proxy/proxy (used by CLI /
# GitHub Action / self-hosted runners to reach connected providers). Same
# strict-Zod validation as LLM_PROXY_LIMITS.
#   rate_per_min         — per-principal call rate (default: 100)
#   max_request_bytes    — max provider request body size (default: 10485760 / 10 MiB)
#   max_response_bytes   — max provider response body size (default: 52428800 / 50 MiB)
#   session_ttl_seconds  — cookie-jar session TTL (default: 3600)
# CREDENTIAL_PROXY_LIMITS='{"rate_per_min":100,"max_request_bytes":10485760,"max_response_bytes":52428800,"session_ttl_seconds":3600}'

# OIDC instance-level satellite clients (JSON array) — declarative provisioning
# of OAuth clients for admin dashboards, second-party web apps, and trusted
# confidential satellites that share the Appstrate login. Reconciled at boot by
# the `oidc` module: create-only with fail-on-drift. To change a field, DELETE
# the oauth_clients row manually and restart (any silent update to redirectUris
# in prod would invalidate in-flight sessions). Secret must be ≥32 chars and is
# stored SHA-256-hashed at rest. Full field reference + sync policy + satellite
# flow: apps/api/src/modules/oidc/README.md#instance-level-satellite-clients-via-oidc_instance_clients
# OIDC_INSTANCE_CLIENTS='[{"clientId":"admin-dashboard","clientSecret":"replace-with-openssl-rand-base64-32","name":"Admin Dashboard","redirectUris":["https://admin.example.com/auth/callback"],"postLogoutRedirectUris":["https://admin.example.com"],"scopes":["openid","profile","email","offline_access"],"skipConsent":false}]'

# ─── Optional: Social Login ──────────────────────────────────

# Google Sign-In (requires Google OAuth App)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub Sign-In (requires GitHub OAuth App — not GitHub App)
# GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ─── Optional: Email Verification ────────────────────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# ─── Optional: Auth lockdown (self-hosting closed mode) ──────
# Default behavior is open mode: anyone reaching the instance may sign up
# and create their own organization (good for SaaS / demo). Self-hosters who
# want closed/invitation-only mode flip these on. Full guide + recipes:
# examples/self-hosting/AUTH_MODES.md
#
# AUTH_DISABLE_SIGNUP=true      # block new account creation (3 exceptions: pending invite, platform admin, bootstrap owner)
# AUTH_DISABLE_ORG_CREATION=true  # restrict POST /api/orgs to platform admins; org-less users see "waiting for invitation"
# AUTH_PLATFORM_ADMIN_EMAILS=admin@acme.com,ops@acme.com
# AUTH_ALLOWED_SIGNUP_DOMAINS=acme.com,foo.io   # comma-separated email domain allowlist (case-insensitive, no leading "@")
# AUTH_BOOTSTRAP_OWNER_EMAIL=admin@acme.com     # auto-creates root org with this user as owner on first signup (idempotent)
# AUTH_BOOTSTRAP_ORG_NAME=Default               # display name of the bootstrap org (defaults to "Default")

# ─── Optional: Auth secret rotation ──────────────────────────
# Active key id used by HMACs/cookies WE sign (e.g. pending-client cookie).
# Rotation: add new secret to BETTER_AUTH_SECRETS under a fresh kid → flip
# BETTER_AUTH_ACTIVE_KID → restart → wait out longest cookie TTL (10 min for
# pending-client) → drop old kid. The Better Auth session cookie itself is
# signed with the active secret only and still requires re-login on rotation.
# BETTER_AUTH_ACTIVE_KID=k1
# BETTER_AUTH_SECRETS='{"k1":"<old-secret>","k2":"<new-secret>"}'

# ─── Optional: AFPS bundle signing ───────────────────────────
# Trust root for Ed25519-signed .afps-bundle files. Bundles signed by a key
# not in this list (directly or via chain) are rejected when policy=required.
# AFPS_TRUST_ROOT='[{"keyId":"acme-prod","publicKey":"<base64>","comment":"acme production signing key"}]'
# AFPS_SIGNATURE_POLICY=off    # off (default) | warn | required

# ─── Optional: Remote runner protocol (CLI / GitHub Action) ──
# Governs the unified event-ingestion surface shared by platform containers
# and remote runners. Spec: docs/specs/REMOTE_CLI_UNIFIED_RUNNER_PLAN.md.
# REMOTE_RUN_SINK_DEFAULT_TTL_SECONDS=7200    # default sink TTL when caller doesn't request one (2h)
# REMOTE_RUN_SINK_MAX_TTL_SECONDS=86400       # hard ceiling on caller-requested TTL (24h)
# REMOTE_RUN_REPLAY_WINDOW_SECONDS=600        # Redis dedup window (must exceed Standard Webhooks 5 min tolerance)
# REMOTE_RUN_BUFFER_FLUSH_MS=5000             # out-of-order event buffer flush window
# REMOTE_RUN_EVENT_LIMITS='{}'                # per-run event-route rate limits (parsed at boot)

# ─── Optional: Run liveness watchdog ─────────────────────────
# Stall watchdog + runner-side heartbeat form a unified detection path
# across every runner topology (platform container, CLI, GitHub Action).
# Rule of thumb: stall_threshold ≥ 3 × heartbeat_interval.
# RUN_HEARTBEAT_INTERVAL_SECONDS=15
# RUN_STALL_THRESHOLD_SECONDS=60
# RUN_WATCHDOG_INTERVAL_SECONDS=15

# ─── Optional: OAuth model-provider refresh worker ──────────
# Proactively refreshes OAuth credentials whose access_token is within
# the lead window so the next agent run doesn't pay a 401-retry on the
# hot path. Off by default — the sidecar's 401 retry + on-demand token
# resolver cover correctness. Enable when long dormant credentials
# would otherwise outlive their refresh_token upstream.
# OAUTH_REFRESH_WORKER_ENABLED=false

# ─── Optional: Integration refresh-failure escalation ────────
# When an integration's OAuth token refresh fails *transiently* (network
# / 5xx — NOT invalid_grant, which flips needs_reconnection at once) this
# many times in a row AND the token is already expired past the grace
# window, the connection is flagged needs_reconnection so the run
# preflight catches it early with an actionable "reconnect" cause instead
# of every scheduled run dying opaquely at integration boot. The expiry
# gate prevents a temporary upstream outage on a still-valid token from
# bricking the connection.
# INTEGRATION_REFRESH_MAX_FAILURES=5
# INTEGRATION_REFRESH_GRACE_SECONDS=3600

# ─── Optional: Sidecar capacity caps ─────────────────────────
# Hard plateau is 100 MB. Loud-fail at boot if invalid (no silent fallback).
# SIDECAR_MAX_REQUEST_BODY_BYTES=10485760     # default 10 MB (sidecar inbound POST size)
# SIDECAR_MAX_MCP_ENVELOPE_BYTES=16777216     # default 16 MB (MCP envelope, sized for base64 inflation)

# ─── Optional: Tool-result truncation cap (#633) ─────────────
# Per-tool-result byte cap applied by the runner BEFORE the result reaches the
# event sink and `run_logs` — write-time truncation: whatever is cut here is
# unrecoverable through `getRunLogs`. Raise it when consumers read run output
# from the logs and 2 KB tool results lose the part they need. Keep it
# comfortably below 32768: the platform drops any `run_logs.data` payload
# exceeding 32 KB wholesale (runLogDataSchema), which is worse than truncation.
# Forwarded into agent containers automatically; invalid values fall back to
# the default.
# TOOL_RESULT_BYTE_LIMIT=2048                 # default 2 KB (per tool result)

# ─── Optional: Sidecar token-budget overrides (#464) ─────────
# Per-call and cumulative-per-run inline-vs-spill thresholds for `provider_call`
# tool outputs. The sidecar's TokenBudget refuses to inline content that would
# exceed these (or the upstream model's context-window minus its `maxTokens`
# reserve, when the launcher forwards them) and spills to the run-scoped blob
# store instead. Defaults stay conservative for the OSS / dev 200 K-context
# Sonnet target; raise them on 1 M-token deployments if you're hitting
# premature spilling.
# SIDECAR_INLINE_TOOL_OUTPUT_TOKENS=8000      # default 8000 (per-call inline cap)
# SIDECAR_RUN_TOOL_OUTPUT_BUDGET_TOKENS=100000 # default 100000 (cumulative ceiling per run)

# ─── Optional: Observability (OpenTelemetry) ─────────────────
# Production telemetry export via OTLP/HTTP. DISABLED by default — enabling is
# a two-step, layered opt-in:
#   1. Append @appstrate/module-observability to MODULES (NOT in the default
#      set — without the module these vars are inert and zero OTel code loads).
#   2. Set OTEL_EXPORTER_OTLP_ENDPOINT (or OTEL_ENABLED=true).
# With the module loaded but no endpoint configured, the bootstrap is still a
# complete no-op (zero spans, zero meters, zero overhead). The vars are read
# from process.env by the module — not part of the @appstrate/env schema.
# Collector-agnostic: point it at any OTLP/HTTP backend (OpenTelemetry
# Collector, Grafana Alloy, Honeycomb, …). See docs/architecture/OBSERVABILITY.md.
#
# Enabled-state = module in MODULES AND (OTEL_ENABLED=true OR a non-empty OTEL_EXPORTER_OTLP_ENDPOINT).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # base OTLP endpoint (signal path appended)
# OTEL_ENABLED=false                                   # force-enable without an explicit endpoint (uses OTLP default)
# OTEL_SERVICE_NAME=appstrate-api                      # service.name resource attribute
# OTEL_TRUST_INCOMING_TRACE=false                      # trust inbound traceparent for span parenting (off by default — see OBSERVABILITY.md)
# Standard OTLP env vars are honored too: OTEL_EXPORTER_OTLP_HEADERS, OTEL_EXPORTER_OTLP_PROTOCOL, …

# ─── Optional: Documents (durable uploads + agent outputs) ───
# DOCUMENT_MAX_FILE_BYTES=104857600         # per-file ceiling for a durable document (default 100 MiB); over-cap → 413
# RUN_MAX_OUTPUT_BYTES=268435456            # total bytes a single run may publish as output (default 256 MiB); over-cap → 413
# ORG_STORAGE_QUOTA_BYTES=                  # per-org durable-storage quota in bytes; unset = unlimited (over-cap → 403 storage_limit_exceeded)
# DOCUMENT_RETENTION_DAYS=                  # auto-expire documents this many days after creation; unset = permanent (never expire)
# USERCONTENT_URL=https://usercontent.example.com  # separate origin for agent-HTML previews (see below); unset = previews served same-origin on APP_URL

# ─── Optional: Misc ──────────────────────────────────────────
# NODE_ENV=production            # gates production-only invariants (e.g. APP_URL https)
# API_BODY_LIMIT_BYTES=10485760   # global request body cap (Hono bodyLimit middleware)
# S3_PUBLIC_ENDPOINT=https://cdn.example.com   # opt-out of proxy uploads: browsers PUT presigned URLs straight at this public S3 endpoint (unset = uploads proxy through APP_URL, bucket stays private)
# LEGAL_TERMS_URL=https://example.com/terms
# LEGAL_PRIVACY_URL=https://example.com/privacy
