# ─── Appstrate — Development Environment ───────────────────────
#
# This file works AS-IS for Tier 0 (zero-install, no Docker).
# Just run: cp .env.example .env && bun run dev
#
# Appstrate uses progressive infrastructure — uncomment sections
# below to scale up from Tier 0 to Tier 3.
#
# Authoritative validation: packages/env/src/index.ts (Zod schema)
# ────────────────────────────────────────────────────────────────

# ─── Modules (comma-separated specifiers) ────────────────────
# Built-in OSS modules (oidc, webhooks) are loaded by default.
# Append external module specifiers to extend, or remove an id to disable.
MODULES=oidc,webhooks

# ─── Required (all tiers) ─────────────────────────────────────

APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
PORT=3000

# Trust proxy — controls how `lib/client-ip.ts` reads X-Forwarded-For.
#
# CRITICAL: must match your deployment topology exactly. X-Forwarded-For
# is used by rate limiters (including the OIDC /oauth2/token brute-force
# limiter) and audit logs — a misconfigured TRUST_PROXY lets an attacker
# inject a spoofed client IP via the XFF header and bypass per-IP limits.
#
#   false  — direct exposure, XFF ignored (default, safest for dev/tier-0)
#   true   — 1 trusted reverse proxy in front of the app (== "1")
#   N      — N trusted proxy hops (e.g. "2" behind a CDN + LB)
#
# Set this ONLY if every hop between the public internet and the app is
# a proxy YOU control that strips untrusted XFF from incoming requests.
# If unsure, leave "false" — the rate limiters will fall back to the
# socket peer address, which cannot be spoofed.
# TRUST_PROXY=false

# Auth — ⚠️ DEV ONLY — regenerate for production: openssl rand -hex 32
BETTER_AUTH_SECRET=appstrate-dev-auth-secret-do-not-use-in-production
RUN_TOKEN_SECRET=appstrate-dev-token-secret-do-not-use-in-production
UPLOAD_SIGNING_SECRET=appstrate-dev-upload-secret-do-not-use-in-production

# Credential encryption — ⚠️ DEV ONLY — regenerate for production: openssl rand -base64 32
CONNECTION_ENCRYPTION_KEY=jChGxOEG1YjCtrkrTYhO7FFdIKaHpe/j1PBY/LqID6s=

# ─── Tier 1+ (PostgreSQL) ────────────────────────────────────
# Uncomment to use an external PostgreSQL instead of PGlite (embedded).
# Start with: bun run docker:dev:minimal

# DATABASE_URL=postgresql://appstrate:appstrate@localhost:5423/appstrate
# POSTGRES_USER=appstrate        # used by docker-compose
# POSTGRES_PASSWORD=appstrate    # used by docker-compose

# ─── Tier 2+ (Redis) ─────────────────────────────────────────
# Uncomment for persistent scheduling and multi-instance support.
# Start with: bun run docker:dev:standard

# REDIS_URL=redis://localhost:6379

# ─── Tier 3 (S3 + Docker execution) ──────────────────────────
# Uncomment for S3 storage and Docker-isolated agent execution.
# Start with: bun run docker:dev

# S3_BUCKET=appstrate
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# MINIO_ROOT_USER=minioadmin     # used by docker-compose
# MINIO_ROOT_PASSWORD=minioadmin
# RUN_ADAPTER=docker
# SIDECAR_POOL_SIZE=2
# DOCKER_SOCKET=/var/run/docker.sock

# ─── Optional (all tiers) ────────────────────────────────────

# Filesystem storage path (Tier 0-2, when S3_BUCKET is absent)
# FS_STORAGE_PATH=./data/storage

# PGlite data directory (Tier 0, when DATABASE_URL is absent)
# PGLITE_DATA_DIR=./data/pglite

# Cookie domain (cross-subdomain auth)
# COOKIE_DOMAIN=.appstrate.com

# Runtime images (override for GHCR / custom registries)
# PI_IMAGE=ghcr.io/appstrate/appstrate-pi:latest
# SIDECAR_IMAGE=ghcr.io/appstrate/appstrate-sidecar:latest

# Platform API URL (how sidecar reaches host — fallback computed at runtime)
# PLATFORM_API_URL=http://localhost:3000

# Outbound proxy for execution containers
# PROXY_URL=http://user:pass@proxy.example.com:22225

# Logging (default: info)
# LOG_LEVEL=info

# System provider keys (JSON array) — pre-configured LLM provider credentials
# SYSTEM_PROVIDER_KEYS='[{"id":"anthropic","label":"Anthropic","api":"anthropic-messages","baseUrl":"https://api.anthropic.com","apiKey":"sk-ant-...","models":[{"modelId":"claude-sonnet-4-6","label":"Claude Sonnet 4.6","isDefault":true}]}]'

# System proxies (JSON array)
# SYSTEM_PROXIES='[{"id":"my-proxy","label":"Residential","url":"http://user:pass@host:port","isDefault":true}]'

# ─── Run limits (platform + inline) ──────────────────────────

# Platform-wide run limits — applied to EVERY run (classic + inline + scheduled).
# JSON object; unset keys use the defaults shown. Validated strictly at boot
# (apps/api/src/services/run-limits.ts) — typos fail-fast.
#   timeout_ceiling_seconds    — hard cap on manifest.timeout (default: 1800)
#   per_org_global_rate_per_min — per-org run creation rate (default: 200)
#   max_concurrent_per_org     — max in-flight runs per org (default: 50)
# PLATFORM_RUN_LIMITS='{"timeout_ceiling_seconds":1800,"per_org_global_rate_per_min":200,"max_concurrent_per_org":50}'

# Inline-run caps — applied on top of PLATFORM_RUN_LIMITS for POST /api/runs/inline.
# Validated strictly at boot. Full spec: docs/specs/INLINE_RUNS.md §7.
#   rate_per_min         — per-user rate for /runs/inline + /runs/inline/validate (default: 60)
#   manifest_bytes       — max manifest size in UTF-8 bytes (default: 65536)
#   prompt_bytes         — max prompt size in UTF-8 bytes (default: 200000)
#   max_skills           — max entries in dependencies.skills (default: 20)
#   max_tools            — max entries in dependencies.tools (default: 20)
#   max_authorized_uris  — cap on authorizedUris + providers count (default: 50)
#   wildcard_uri_allowed — allow "*" / allowAllUris in provider manifests (default: false)
#   retention_days       — days before shadow manifest/prompt are NULLed by compaction (default: 30)
# INLINE_RUN_LIMITS='{"rate_per_min":60,"manifest_bytes":65536,"prompt_bytes":200000,"max_skills":20,"max_tools":20,"max_authorized_uris":50,"wildcard_uri_allowed":false,"retention_days":30}'

# OIDC instance-level satellite clients (JSON array) — declarative provisioning
# of OAuth clients for admin dashboards, second-party web apps, and trusted
# confidential satellites that share the Appstrate login. Reconciled at boot by
# the `oidc` module: create-only with fail-on-drift. To change a field, DELETE
# the oauth_clients row manually and restart (any silent update to redirectUris
# in prod would invalidate in-flight sessions). Secret must be ≥32 chars and is
# stored SHA-256-hashed at rest. Full field reference + sync policy + satellite
# flow: apps/api/src/modules/oidc/README.md#instance-level-satellite-clients-via-oidc_instance_clients
# OIDC_INSTANCE_CLIENTS='[{"clientId":"admin-dashboard","clientSecret":"replace-with-openssl-rand-base64-32","name":"Admin Dashboard","redirectUris":["https://admin.example.com/auth/callback"],"postLogoutRedirectUris":["https://admin.example.com"],"scopes":["openid","profile","email","offline_access"],"skipConsent":false}]'

# ─── Optional: Social Login ──────────────────────────────────

# Google Sign-In (requires Google OAuth App)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub Sign-In (requires GitHub OAuth App — not GitHub App)
# GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ─── Optional: Email Verification ────────────────────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com
