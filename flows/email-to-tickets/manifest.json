{
  "$schema": "https://openflows.dev/schemas/manifest-v1.json",
  "version": "1.0.0",

  "metadata": {
    "name": "email-to-tickets",
    "displayName": "Email → Tickets",
    "description": "Lit les mails récents et crée des tickets pour les actions à traiter",
    "author": "openflows",
    "license": "MIT",
    "tags": ["email", "productivité", "tickets"]
  },

  "requires": {
    "services": [
      {
        "id": "gmail",
        "provider": "google-mail",
        "scopes": ["https://www.googleapis.com/auth/gmail.readonly"],
        "description": "Lecture des mails"
      },
      {
        "id": "clickup",
        "provider": "clickup",
        "scopes": ["task:write"],
        "description": "Création de tickets"
      }
    ],
    "tools": [
      {
        "id": "web-search",
        "type": "static",
        "description": "Recherche web pour enrichir les tickets"
      }
    ]
  },

  "state": {
    "enabled": true,
    "schema": {
      "last_run": { "type": "string", "format": "date-time" },
      "last_email_id": { "type": "string" }
    }
  },

  "config": {
    "schema": {
      "max_emails": {
        "type": "number",
        "default": 20,
        "description": "Nombre maximum de mails à traiter par exécution"
      },
      "clickup_list_id": {
        "type": "string",
        "required": true,
        "description": "ID de la liste ClickUp où créer les tickets"
      },
      "language": {
        "type": "string",
        "default": "fr",
        "enum": ["fr", "en"],
        "description": "Langue des résumés et tickets"
      }
    }
  },

  "execution": {
    "timeout": 300,
    "maxTokens": 100000
  }
}
