{
  "$schema": "https://appstrate.dev/schemas/manifest-v1.json",
  "version": "1.0.0",

  "metadata": {
    "name": "clickup-summary",
    "displayName": "ClickUp → Résumé",
    "description": "Lit les tickets à faire dans ClickUp et produit un résumé priorisé",
    "author": "appstrate",
    "license": "MIT",
    "tags": ["clickup", "productivité", "résumé", "tickets"]
  },

  "requires": {
    "services": [
      {
        "id": "clickup",
        "provider": "clickup",
        "scopes": ["task:read"],
        "description": "Lecture des tickets ClickUp"
      }
    ],
    "tools": []
  },

  "state": {
    "enabled": true,
    "schema": {
      "type": "object",
      "properties": {
        "last_run": { "type": "string", "format": "date-time" }
      }
    }
  },

  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "clickup_team_id": {
          "type": "string",
          "description": "ID du workspace (team) ClickUp — visible dans l'URL : app.clickup.com/{team_id}/..."
        },
        "clickup_list_id": {
          "type": "string",
          "description": "ID d'une liste spécifique (optionnel — si vide, récupère les tickets de toutes les listes)"
        },
        "include_subtasks": {
          "type": "boolean",
          "default": true,
          "description": "Inclure les sous-tâches dans l'analyse"
        },
        "language": {
          "type": "string",
          "default": "fr",
          "enum": ["fr", "en"],
          "description": "Langue du résumé"
        }
      },
      "required": ["clickup_team_id"]
    }
  },

  "output": {
    "schema": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Résumé priorisé des tickets ClickUp"
        },
        "tasks": {
          "type": "array",
          "description": "Liste des tickets avec statut et priorité"
        },
        "total_tasks": {
          "type": "number",
          "description": "Nombre total de tickets analysés"
        }
      },
      "required": ["summary", "tasks"]
    }
  },

  "execution": {
    "timeout": 180,
    "maxTokens": 50000
  }
}
