{
  "$schema": "https://appstrate.dev/schemas/manifest-v1.json",
  "version": "1.0.0",

  "metadata": {
    "name": "newsletter-search",
    "displayName": "Recherche newsletters",
    "description": "Recherche et résume les newsletters sur un sujet donné",
    "author": "appstrate",
    "license": "MIT",
    "tags": ["email", "search", "newsletters"]
  },

  "requires": {
    "services": [
      {
        "id": "gmail",
        "provider": "google-mail",
        "scopes": ["https://www.googleapis.com/auth/gmail.readonly"],
        "description": "Accès en lecture aux emails"
      }
    ]
  },

  "input": {
    "schema": {
      "type": "object",
      "properties": {
        "topic": {
          "type": "string",
          "description": "Sujet à rechercher dans les newsletters",
          "placeholder": "ex: intelligence artificielle, crypto, design..."
        }
      },
      "required": ["topic"]
    }
  },

  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "max_emails": {
          "type": "number",
          "description": "Nombre max de mails à analyser",
          "default": 50
        },
        "language": {
          "type": "string",
          "description": "Langue du résumé",
          "default": "fr",
          "enum": ["fr", "en"]
        }
      }
    }
  },

  "output": {
    "schema": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Résumé des résultats de la recherche"
        },
        "results": {
          "type": "array",
          "description": "Articles/newsletters pertinents trouvés"
        },
        "newsletters_found": {
          "type": "number",
          "description": "Nombre de newsletters analysées"
        },
        "emails_scanned": {
          "type": "number",
          "description": "Nombre total de mails scannés"
        }
      },
      "required": ["summary", "results"]
    }
  },

  "execution": {
    "timeout": 300,
    "maxTokens": 16000
  }
}
