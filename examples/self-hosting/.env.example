# ─── Appstrate — Self-Hosting Environment Variables ──────────────
#
# This file documents every env var the self-hosted appstrate process
# consumes. Required values are uncommented (operator MUST set them).
# Optional overrides are commented out with `# VAR=<code-default>`;
# uncomment + edit to override.
#
# Defaults are defined in `packages/env/src/index.ts` (Zod schema).
# This file is documentation — when these vars are unset, the in-code
# defaults apply. Mirroring a default in `.env` is harmless; mirroring
# one in `docker-compose.yml` is a maintenance trap (the `MODULES`
# drift in #513 shipped zero model providers to every CLI install for
# weeks). The `verify:compose-defaults` CI guard catches it.
#
# Generate secrets:
#   openssl rand -base64 32   →  BETTER_AUTH_SECRET, UPLOAD_SIGNING_SECRET,
#                                RUN_TOKEN_SECRET, CONNECTION_ENCRYPTION_KEY
# ────────────────────────────────────────────────────────────────────

# ─── Required secrets (no defaults — instance will not boot) ──────

# Better Auth session-signing secret.
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# Dedicated HMAC secret for FS upload-sink tokens. Rotates independently
# of BETTER_AUTH_SECRET. Must be at least 16 characters.
UPLOAD_SIGNING_SECRET=<generate-with-openssl-rand-base64-32>

# Connection-blob encryption key. Must be exactly 32 bytes base64-encoded
# (256-bit). Used as the primary key for new ciphertexts (v1 envelope:
# `v1:<kid>:<base64(iv|authTag|ciphertext)>`).
CONNECTION_ENCRYPTION_KEY=<generate-with-openssl-rand-base64-32>

# ─── Required infra (compose plumbing) ────────────────────────────

# PostgreSQL admin user/password. Used by the `postgres` service AND
# composed into DATABASE_URL inside the compose file.
POSTGRES_USER=appstrate
POSTGRES_PASSWORD=<generate-with-openssl-rand-base64-32>

# MinIO root credentials (tier 3 only). Composed into AWS_* env vars
# inside the compose file.
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=<generate-with-openssl-rand-base64-32>

# ─── Object storage (tier 3, S3 / MinIO) ──────────────────────────
# Setting S3_BUCKET switches the platform from filesystem storage to S3.
# When set, S3_REGION is required (Zod refinement enforces this at boot).

# S3 bucket name.
# S3_BUCKET=appstrate

# S3 region. Required when S3_BUCKET is set.
# S3_REGION=us-east-1

# ─── Platform ─────────────────────────────────────────────────────

# Public URL for OAuth callbacks. Must be https:// in NODE_ENV=production
# (localhost is exempt).
# APP_URL=http://localhost:3000

# Server port.
# PORT=3000

# CORS origins (comma-separated). The code default allows dev localhost
# ports, which is wrong for prod self-host — compose ships an empty
# default so operators opt in to their public domain explicitly.
# TRUSTED_ORIGINS=https://appstrate.example.com

# Trust proxy: "false" (XFF ignored, safest), "true" (=1 trusted hop),
# or "N" (N trusted hops). Misconfig lets attackers spoof client IP
# via X-Forwarded-For — set only when every hop in front of the app
# is a proxy YOU control that strips untrusted XFF.
# TRUST_PROXY=false

# Log level: debug | info | warn | error.
# LOG_LEVEL=info

# Cookie domain for cross-subdomain auth.
# COOKIE_DOMAIN=.example.com

# Opt-out of proxy uploads (advanced). Unset (default): upload URLs point at
# APP_URL and the platform streams bytes to the bucket server-side — MinIO/S3
# stays fully private. Set: browsers PUT presigned URLs straight at this
# public S3 endpoint (must be reachable at a domain root).
# S3_PUBLIC_ENDPOINT=https://s3.example.com

# ─── Execution ────────────────────────────────────────────────────

# Run adapter: 'docker' (sandboxed containers, required for prod) or
# 'process' (Bun subprocesses, dev only — no isolation). The compose
# file overrides the code default `process` to `docker`.
# RUN_ADAPTER=docker

# Docker socket group ID — auto-detected by the installer.
# Linux: GID of the `docker` group (often 998).
# macOS Docker Desktop: 0 (root) — the socket is rewritten in containers.
# DOCKER_GID=0

# Firecracker (co-located UDS transport only): HOST directory holding the
# runner daemon's unix socket, bind-mounted at /run/appstrate-runner inside
# the platform container. Set by the firecracker installer; leave unset
# otherwise — the compose templates fall back to a harmless empty local dir.
# APPSTRATE_RUNNER_SOCKET_DIR=/run/appstrate-runner

# ─── Modules ──────────────────────────────────────────────────────

# Comma-separated module specifiers loaded at boot. Default ships
# (OSS, API-key only):
#   - oidc            — OAuth 2.1 / OIDC identity provider
#   - webhooks        — Standard Webhooks event delivery
#   - mcp             — platform MCP server
#   - core-providers  — OpenAI / Anthropic / OpenAI-compat API keys
#
# OPT-IN subscription providers (NOT loaded by default — a personal
# ChatGPT/Claude subscription powering a product is an operator-owned
# grey-zone; see docs/architecture/SUBSCRIPTION_COMPLIANCE.md):
#   - @appstrate/module-codex       — ChatGPT/Codex OAuth
#   - @appstrate/module-claude-code — Claude Pro/Max/Team OAuth
# Append them deliberately after reviewing the upstream ToS, or append
# external npm specifiers to extend (e.g. `,@scope/my-module`).
# MODULES=oidc,webhooks,mcp,core-providers,@appstrate/module-chat,@appstrate/module-codex,@appstrate/module-claude-code

# ─── LLM Provider (at least one required for agent runs) ──────────

# JSON array of system provider keys (credentials + per-provider model
# list). `providerId` must match a registered ModelProviderDefinition
# (anthropic, openai, openai-compatible, cerebras, google-ai, groq,
# mistral, openrouter, xai). For openai-compatible, set `baseUrlOverride`
# to point at a custom endpoint (vLLM, Ollama, LiteLLM, …).
# SYSTEM_PROVIDER_KEYS='[{"id":"anthropic","providerId":"anthropic","apiKey":"sk-ant-...","models":[{"modelId":"claude-sonnet-4-6","isDefault":true}]}]'

# JSON array of system proxy definitions.
# SYSTEM_PROXIES='[{"id":"my-proxy","label":"Residential","url":"http://user:pass@host:port","isDefault":true}]'

# Outbound HTTP proxy URL injected into sidecar containers.
# PROXY_URL=http://user:pass@proxy.example.com:22225

# ─── Auth lockdown (closed mode) ──────────────────────────────────
# Default is "open mode": anyone reaching the instance may sign up and
# create their own organization (good for SaaS / demo). Flip these for
# private/invitation-only deployments. Full guide: AUTH_MODES.md.

# AUTH_DISABLE_SIGNUP=false
# AUTH_DISABLE_ORG_CREATION=false
# AUTH_PLATFORM_ADMIN_EMAILS=admin@example.com
# AUTH_ALLOWED_SIGNUP_DOMAINS=example.com,partner.io
# AUTH_BOOTSTRAP_OWNER_EMAIL=admin@example.com
# AUTH_BOOTSTRAP_ORG_NAME=Default

# One-shot bootstrap-claim token (CLI `appstrate install --yes` generates
# this for unattended installs). Base64url, 22-128 chars. Cleared in
# memory after a single POST to /api/auth/bootstrap/redeem.
# AUTH_BOOTSTRAP_TOKEN=

# ─── Auth secret rotation ─────────────────────────────────────────
# Rotation playbook: add new secret under fresh kid in BETTER_AUTH_SECRETS
# → flip BETTER_AUTH_ACTIVE_KID → restart → wait out longest cookie TTL
# (10 min for pending-client) → drop old kid + restart.

# BETTER_AUTH_ACTIVE_KID=k1
# JSON map { kid: secret }. Empty {} means use BETTER_AUTH_SECRET under
# the active kid. Compose ships an EMPTY string default (not `{}`) to
# neutralize better-auth 1.6+'s own BETTER_AUTH_SECRETS CSV parser.
# BETTER_AUTH_SECRETS=

# ─── Credential encryption rotation ───────────────────────────────

# Active kid embedded in newly-encrypted credential blobs. Stable across
# deploys; only flip when promoting a freshly-rotated key.
# CONNECTION_ENCRYPTION_KEY_ID=k1

# Retired keys held for decrypt-only during a rotation window. JSON map:
#   { "old_kid": "<base64 32-byte key>" }
# CONNECTION_ENCRYPTION_KEYS={}

# ─── Run token signing ────────────────────────────────────────────

# Run token signing secret. If unset, run tokens are unsigned (only
# acceptable for single-instance trust boundaries).
# RUN_TOKEN_SECRET=<generate-with-openssl-rand-base64-32>

# ─── AFPS bundle signing ──────────────────────────────────────────

# JSON array of trusted publishers for .afps-bundle Ed25519 verification.
# AFPS_TRUST_ROOT='[{"keyId":"acme-prod","publicKey":"<base64>","comment":"acme production signing key"}]'

# Signature policy: off (no verification) | warn (verify if signed) |
# required (reject unsigned/invalid).
# AFPS_SIGNATURE_POLICY=off

# ─── Sidecar capacity caps ────────────────────────────────────────
# Hard ceiling 100 MB. Loud-fail at boot if invalid. Forwarded by
# pickOperatorSidecarEnv from process.env into sidecar/agent containers.

# Sidecar inbound POST size cap.
# SIDECAR_MAX_REQUEST_BODY_BYTES=10485760

# MCP envelope cap, sized for base64 inflation.
# SIDECAR_MAX_MCP_ENVELOPE_BYTES=16777216

# ─── Remote runner protocol (CLI / GitHub Action) ─────────────────
# Governs the unified event-ingestion surface shared by platform
# containers and remote runners.

# Default sink TTL when caller doesn't request one (seconds, 2h).
# REMOTE_RUN_SINK_DEFAULT_TTL_SECONDS=7200

# Hard ceiling on caller-requested TTL (24h).
# REMOTE_RUN_SINK_MAX_TTL_SECONDS=86400

# Redis dedup window for webhook-id replay detection. MUST exceed the
# Standard Webhooks 5-min timestamp tolerance.
# REMOTE_RUN_REPLAY_WINDOW_SECONDS=600

# Out-of-order event buffer flush window (ms). Terminal events flush
# immediately regardless of gaps.
# REMOTE_RUN_BUFFER_FLUSH_MS=5000

# Per-run event-route rate limits (JSON object, parsed at route-build).
# REMOTE_RUN_EVENT_LIMITS={}

# Standard Webhooks `webhook-timestamp` tolerance (seconds). Must stay
# strictly less than REMOTE_RUN_REPLAY_WINDOW_SECONDS.
# WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# ─── Run liveness watchdog ────────────────────────────────────────
# Rule of thumb: stall_threshold ≥ 3 × heartbeat_interval.

# RUN_HEARTBEAT_INTERVAL_SECONDS=15
# RUN_STALL_THRESHOLD_SECONDS=60
# RUN_WATCHDOG_INTERVAL_SECONDS=15

# ─── OAuth model-provider refresh worker ──────────────────────────

# Proactively refreshes OAuth credentials whose access_token is within
# the lead window. Off by default — the sidecar's 401 retry + on-demand
# token resolver cover correctness. Enable when long-dormant credentials
# would otherwise outlive their refresh_token upstream.
# OAUTH_REFRESH_WORKER_ENABLED=false

# ─── Integration refresh-failure escalation ───────────────────────

# When an integration's OAuth token refresh fails *transiently* (network
# / 5xx — NOT invalid_grant) this many times in a row AND the token is
# already expired past the grace window, the connection is flagged
# needs_reconnection so the run preflight catches it early with an
# actionable "reconnect" cause instead of every scheduled run dying
# opaquely at integration boot. The expiry gate prevents a temporary
# upstream outage on a still-valid token from bricking the connection.
# INTEGRATION_REFRESH_MAX_FAILURES=5
# INTEGRATION_REFRESH_GRACE_SECONDS=3600

# ─── Run / proxy limits (JSON, strict validation at boot) ─────────

# Platform-wide run limits — applied to EVERY run (classic + inline +
# scheduled). Keys: timeout_ceiling_seconds (1800),
# per_org_global_rate_per_min (200), max_concurrent_per_org (50).
# PLATFORM_RUN_LIMITS={}

# Inline-run caps. Full spec: docs/specs/INLINE_RUNS.md §7.
# INLINE_RUN_LIMITS={}

# LLM proxy caps on /api/llm-proxy/*. Keys: rate_per_min (60),
# max_request_bytes (10485760).
# LLM_PROXY_LIMITS={}

# Credential proxy caps on /api/credential-proxy/proxy. Keys:
# rate_per_min (100), max_request_bytes (10485760),
# max_response_bytes (52428800), session_ttl_seconds (3600).
# CREDENTIAL_PROXY_LIMITS={}

# ─── OIDC instance-level satellite clients ────────────────────────
# Declarative provisioning of OAuth clients (admin dashboards, second-
# party web apps). Reconciled at boot by the oidc module (create-only,
# fail-on-drift). Full reference: apps/api/src/modules/oidc/README.md.
# OIDC_INSTANCE_CLIENTS='[{"clientId":"admin-dashboard","clientSecret":"<openssl-rand-base64-32>","name":"Admin","redirectUris":["https://admin.example.com/auth/callback"],"postLogoutRedirectUris":["https://admin.example.com"],"scopes":["openid","profile","email","offline_access"],"skipConsent":false}]'

# ─── Social login (optional) ──────────────────────────────────────

# Google Sign-In (requires Google OAuth App).
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub Sign-In (requires GitHub OAuth App — not GitHub App).
# GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ─── Email verification (SMTP — optional) ─────────────────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# ─── Misc (rarely tuned) ──────────────────────────────────────────

# NODE_ENV: development | production | test. Gates production-only
# invariants (e.g. APP_URL must be https).
# NODE_ENV=production

# Global request body cap (Hono bodyLimit middleware). Per-route caps
# still apply on top.
# API_BODY_LIMIT_BYTES=10485760

# Filesystem storage path (when S3_BUCKET is absent).
# FS_STORAGE_PATH=./data/storage

# PGlite data directory (when DATABASE_URL is absent — not typical for
# self-hosting which always supplies PostgreSQL).
# PGLITE_DATA_DIR=./data/pglite

# Legal links (footer).
# LEGAL_TERMS_URL=https://example.com/terms
# LEGAL_PRIVACY_URL=https://example.com/privacy

# ─── Image / version pinning ──────────────────────────────────────

# Override the version tag pulled from GHCR (defaults to `latest`).
# APPSTRATE_VERSION=latest

# Override individual runtime images (e.g. private registry mirrors).
# PI_IMAGE=ghcr.io/appstrate/appstrate-pi:latest
# SIDECAR_IMAGE=ghcr.io/appstrate/appstrate-sidecar:latest

# How sidecars reach the platform. Leave unset in containerized
# deployments — the Docker orchestrator auto-detects the platform
# network. Empty string is treated as unset.
# PLATFORM_API_URL=
