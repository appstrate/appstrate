# Appstrate — Self-Hosting Environment Variables
#
# Copy this file:  cp .env.example .env
# Then edit the values below.
#
# Generate secrets:
#   openssl rand -hex 32      -> BETTER_AUTH_SECRET, RUN_TOKEN_SECRET
#   openssl rand -base64 32   -> CONNECTION_ENCRYPTION_KEY

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=appstrate
POSTGRES_PASSWORD=CHANGE_ME

# ── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=CHANGE_ME
RUN_TOKEN_SECRET=CHANGE_ME
UPLOAD_SIGNING_SECRET=CHANGE_ME

# ── Auth lockdown (closed mode for production self-hosting) ──
# Default is "open mode": anyone who can reach the instance may sign up
# and create their own organization. Good for SaaS / demos. For private
# production deployments, switch to "closed mode" with the env vars
# below. Full guide: examples/self-hosting/AUTH_MODES.md.
#
# AUTH_DISABLE_SIGNUP=true
# AUTH_DISABLE_ORG_CREATION=true
# AUTH_PLATFORM_ADMIN_EMAILS=admin@your-domain.com
# AUTH_BOOTSTRAP_OWNER_EMAIL=admin@your-domain.com
# AUTH_BOOTSTRAP_ORG_NAME=Acme
# AUTH_ALLOWED_SIGNUP_DOMAINS=acme.com,foo.io

# ── Credential Encryption ────────────────────────────────────
CONNECTION_ENCRYPTION_KEY=CHANGE_ME

# ── Object Storage (MinIO) ───────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
S3_BUCKET=appstrate
S3_REGION=us-east-1

# ── Platform ─────────────────────────────────────────────────
APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000
PORT=3000
LOG_LEVEL=info

# ── Execution ────────────────────────────────────────────────
# Run adapter: 'docker' (sandboxed containers, required for self-hosting)
# or 'process' (Bun subprocesses, dev only — no isolation).
RUN_ADAPTER=docker

# Docker socket group ID — auto-detected by the installer.
# Linux: usually the GID of the 'docker' group (e.g. 998).
# macOS Docker Desktop: 0 (root) — the socket is rewritten inside containers.
DOCKER_GID=0

# ── LLM Provider (at least one required for agent runs) ──
# SYSTEM_PROVIDER_KEYS='[{"id":"anthropic","label":"Anthropic","api":"anthropic-messages","baseUrl":"https://api.anthropic.com","apiKey":"sk-ant-...","models":[{"modelId":"claude-sonnet-4-6","label":"Claude Sonnet 4.6","isDefault":true}]}]'

# ── Version (optional, defaults to latest) ───────────────────
# APPSTRATE_VERSION=latest
