{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Flow Manifest",
  "description": "Appstrate flow manifest — extends AFPS flow with x-outputRetries.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "const": "flow"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.(0|[1-9]\\d*)$"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "tools": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "providers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": {}
    },
    "author": {
      "type": "string"
    },
    "providersConfiguration": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "connectionMode": {
            "type": "string",
            "enum": ["user", "admin"]
          }
        },
        "additionalProperties": {}
      }
    },
    "input": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "object"
            },
            "properties": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["string", "number", "boolean", "array", "object", "file"]
                  },
                  "description": {
                    "type": "string"
                  },
                  "default": {},
                  "enum": {
                    "type": "array",
                    "items": {}
                  },
                  "format": {
                    "type": "string"
                  },
                  "placeholder": {
                    "type": "string"
                  },
                  "accept": {
                    "type": "string"
                  },
                  "maxSize": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "multiple": {
                    "type": "boolean"
                  },
                  "maxFiles": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "required": ["type"],
                "additionalProperties": {}
              }
            },
            "required": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "propertyOrder": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["type", "properties"],
          "additionalProperties": {}
        }
      },
      "required": ["schema"],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "object"
            },
            "properties": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["string", "number", "boolean", "array", "object", "file"]
                  },
                  "description": {
                    "type": "string"
                  },
                  "default": {},
                  "enum": {
                    "type": "array",
                    "items": {}
                  },
                  "format": {
                    "type": "string"
                  },
                  "placeholder": {
                    "type": "string"
                  },
                  "accept": {
                    "type": "string"
                  },
                  "maxSize": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "multiple": {
                    "type": "boolean"
                  },
                  "maxFiles": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "required": ["type"],
                "additionalProperties": {}
              }
            },
            "required": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "propertyOrder": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["type", "properties"],
          "additionalProperties": {}
        }
      },
      "required": ["schema"],
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "object"
            },
            "properties": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["string", "number", "boolean", "array", "object", "file"]
                  },
                  "description": {
                    "type": "string"
                  },
                  "default": {},
                  "enum": {
                    "type": "array",
                    "items": {}
                  },
                  "format": {
                    "type": "string"
                  },
                  "placeholder": {
                    "type": "string"
                  },
                  "accept": {
                    "type": "string"
                  },
                  "maxSize": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "multiple": {
                    "type": "boolean"
                  },
                  "maxFiles": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "required": ["type"],
                "additionalProperties": {}
              }
            },
            "required": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "propertyOrder": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["type", "properties"],
          "additionalProperties": {}
        }
      },
      "required": ["schema"],
      "additionalProperties": false
    },
    "timeout": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "x-outputRetries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": ["name", "version", "type", "displayName", "schemaVersion", "author"],
  "additionalProperties": {}
}
