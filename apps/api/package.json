    "drizzle-orm": "^0.39.3",
    "fflate": "^0.8.2",
    "hono": "^4.11.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/semver": "^7.7.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
