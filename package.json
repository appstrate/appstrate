{
  "name": "appstrate",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check": "turbo check",
    "setup-nango": "bun scripts/setup-nango.ts",
    "build-runtime": "docker build -t appstrate-claude-code ./runtime-claude-code",
    "gen:types": "bunx supabase gen types typescript --local > packages/shared-types/src/database.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.1",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
