{
  "name": "appstrate",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@readme/openapi-parser": "^5.5.0",
    "@redocly/openapi-core": "^2.19.1",
    "@types/bun": "latest",
    "@types/semver": "^7.7.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript-eslint": "^8.55.0",
    "@mariozechner/pi-ai": "^0.52.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write \"apps/*/src/**\" \"packages/*/src/**\"",
    "format": "prettier --write \"apps/*/src/**\" \"packages/*/src/**\"",
    "format:check": "prettier --check \"apps/*/src/**\" \"packages/*/src/**\"",
    "check": "turbo typecheck && eslint . && prettier --check \"apps/*/src/**\" \"packages/*/src/**\" && bun scripts/verify-openapi.ts && bun scripts/build-system-packages.ts --check",
    "build-runtime": "docker build -t appstrate-pi ./runtime-pi",
    "build-sidecar": "docker build -t appstrate-sidecar ./runtime-pi/sidecar",
    "db:generate": "set -a && . ./.env && cd packages/db && bunx drizzle-kit generate",
    "db:migrate": "set -a && . ./.env && cd packages/db && bunx drizzle-kit migrate",
    "docker:dev": "docker compose up -d",
    "docker:prod": "docker compose --profile prod up -d",
    "verify:openapi": "bun scripts/verify-openapi.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "runtime-pi",
    "runtime-pi/sidecar"
  ],
  "dependencies": {
    "@appstrate/core": "2.8.8"
  }
}
