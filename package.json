{
  "name": "openflows",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,build -c blue,green \"bun --hot src/index.ts\" \"cd frontend && bunx vite build --watch\"",
    "setup-db": "bun scripts/setup-db.ts",
    "build-runtime": "docker build -t openflows-claude-code ./runtime-claude-code",
    "build:frontend": "cd frontend && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@nangohq/node": "^0.69.30",
    "hono": "^4.11.9",
    "postgres": "^3.4.8"
  }
}
