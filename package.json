{
  "name": "appstrate",
  "description": "[⚡️] Open-source Agent as a Service platform",
  "homepage": "https://github.com/appstrate/appstrate",
  "repository": {
    "type": "git",
    "url": "https://github.com/appstrate/appstrate.git"
  },
  "bugs": {
    "url": "https://github.com/appstrate/appstrate/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "docker",
    "automation",
    "llm"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-ai": "0.73.1",
    "@readme/openapi-parser": "^6.3.0",
    "@redocly/openapi-core": "^2.39.0",
    "@types/bun": "latest",
    "@types/json-schema": "7.0.15",
    "@types/semver": "^7.7.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "turbo": "^2.10.5",
    "type-coverage": "^2.29.7",
    "typescript-eslint": "^8.64.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage",
    "test:tier0": "TEST_TIER=0 bun test",
    "test:docker": "TEST_DOCKER=1 bun test",
    "test:unit": "bun test apps/api/test/unit/",
    "test:watch": "bun test --watch apps/api/test/unit/",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:api": "cd e2e && npx playwright test --project=api",
    "test:e2e:ui": "cd e2e && npx playwright test --project=ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write \"apps/*/src/**\" \"packages/*/src/**\"",
    "format": "prettier --write \"apps/*/src/**\" \"packages/*/src/**\"",
    "format:check": "prettier --check \"apps/*/src/**\" \"packages/*/src/**\"",
    "detect:breaking": "bun scripts/detect-breaking-changes.ts",
    "generate:api": "bun scripts/generate-api-types.ts",
    "verify:api-types": "bun scripts/generate-api-types.ts --check",
    "build:system-packages": "bun scripts/build-system-packages.ts",
    "build:system-packages:check": "bun scripts/build-system-packages.ts --check",
    "lint:manifest-casing": "bun scripts/lint-manifest-casing.ts",
    "conformance:check": "bun scripts/conformance/run.ts --tier gate",
    "test:system-packages": "bun scripts/conformance/run.ts",
    "check": "turbo typecheck lint format:check verify:openapi verify:api-types verify:type-coverage verify:compose-defaults detect:breaking build:system-packages:check lint:manifest-casing conformance:check verify:module-isolation typecheck:scripts verify:module-contract",
    "verify:module-isolation": "bun scripts/verify-module-isolation.ts",
    "verify:module-contract": "bun scripts/verify-module-contract.ts",
    "typecheck:scripts": "tsc --noEmit -p scripts/tsconfig.json",
    "build-runtime": "bun run docker:build:runtime",
    "build-sidecar": "bun run docker:build:sidecar",
    "docker:build:runtime": "docker build -t appstrate-pi -f ./runtime-pi/Dockerfile .",
    "docker:build:sidecar": "docker build -t appstrate-sidecar -f ./runtime-pi/sidecar/Dockerfile .",
    "docker:build:runner:node": "docker build -t appstrate-mcp-runner-node:latest -f ./runtime-pi/runners/node/Dockerfile ./runtime-pi/runners/node/",
    "docker:build:runner:python": "docker build -t appstrate-mcp-runner-python:latest -f ./runtime-pi/runners/python/Dockerfile ./runtime-pi/runners/python/",
    "docker:build:runner:binary": "docker build -t appstrate-mcp-runner-binary:latest -f ./runtime-pi/runners/binary/Dockerfile ./runtime-pi/runners/binary/",
    "docker:build:runner:bun": "docker build -t appstrate-mcp-runner-bun:latest -f ./runtime-pi/runners/bun/Dockerfile ./runtime-pi/runners/bun/",
    "docker:build:runner:uv": "docker build -t appstrate-mcp-runner-uv:latest -f ./runtime-pi/runners/uv/Dockerfile ./runtime-pi/runners/uv/",
    "docker:build:runners": "bun run docker:build:runner:node && bun run docker:build:runner:python && bun run docker:build:runner:binary && bun run docker:build:runner:bun && bun run docker:build:runner:uv",
    "docker:build:all": "bun run docker:build:runtime && bun run docker:build:sidecar && bun run docker:build:runners",
    "firecracker:build": "bash apps/api/src/modules/firecracker/scripts/build-rootfs.sh && bash apps/api/src/modules/firecracker/scripts/build-kernel.sh",
    "firecracker:build:rootfs": "bash apps/api/src/modules/firecracker/scripts/build-rootfs.sh",
    "firecracker:build:kernel": "bash apps/api/src/modules/firecracker/scripts/build-kernel.sh",
    "firecracker:runner": "bun apps/api/src/modules/firecracker/runner/daemon.ts",
    "test:firecracker": "bash apps/api/src/modules/firecracker/scripts/dev/run-in-vm.sh",
    "db:generate": "cd packages/db && bunx drizzle-kit generate",
    "db:migrate": "cd packages/db && bunx drizzle-kit migrate",
    "preinstall": "which bun > /dev/null 2>&1 || (echo '\\033[31mThis project requires Bun. Install it: https://bun.sh\\033[0m' && exit 1)",
    "setup": "bun scripts/setup.ts",
    "docker:dev": "docker compose -f docker-compose.dev.yml --profile full up -d",
    "docker:dev:minimal": "docker compose -f docker-compose.dev.yml --profile minimal up -d",
    "docker:dev:standard": "docker compose -f docker-compose.dev.yml --profile standard up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:prod": "docker compose --profile prod up -d",
    "docker:prod:down": "docker compose --profile prod down",
    "docker:prod:logs": "docker compose --profile prod logs -f",
    "docker:clean": "docker compose down -v && docker compose -f docker-compose.dev.yml down -v",
    "test:integration": "bun test apps/api/test/integration/",
    "db:studio": "cd packages/db && bunx drizzle-kit studio",
    "verify:openapi": "bun scripts/verify-openapi.ts",
    "verify:type-coverage": "type-coverage --project apps/web/tsconfig.json --strict --at-least 98 --ignore-files \"src/api/schema.d.ts\"",
    "verify:compose-defaults": "bun scripts/verify-compose-defaults.ts",
    "openapi:baseline": "bun scripts/detect-breaking-changes.ts --update-baseline",
    "openapi:diff": "bun scripts/detect-breaking-changes.ts",
    "clean": "rm -rf node_modules/.cache .turbo apps/*/dist apps/web/.vite packages/*/dist coverage",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "runtime-pi",
    "runtime-pi/sidecar",
    "e2e"
  ],
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@afps-spec/schema": "^0.6.1",
    "@appstrate/connect": "workspace:*",
    "@appstrate/core": "workspace:*",
    "@appstrate/mcp-transport": "workspace:*",
    "@electric-sql/pglite": "^0.5.4",
    "ajv": "^8.20.0"
  },
  "overrides": {
    "zod": "4.4.3",
    "ai": "^7.0.33",
    "@ai-sdk/mcp": "^2.0.16",
    "@ai-sdk/react": "^4.0.36",
    "@ai-sdk/provider-utils": "^5.0.12"
  },
  "patchedDependencies": {
    "@redocly/openapi-core@2.25.2": "patches/@redocly%2Fopenapi-core@2.25.2.patch",
    "@better-auth/oauth-provider@1.7.0-beta.4": "patches/@better-auth%2Foauth-provider@1.7.0-beta.4.patch",
    "@better-auth/cimd@1.7.0-beta.4": "patches/@better-auth%2Fcimd@1.7.0-beta.4.patch"
  }
}
