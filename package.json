{
  "name": "appstrate",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check": "turbo check && bun scripts/verify-openapi.ts",
    "build-runtime": "docker build -t appstrate-pi ./runtime-pi",
    "build-sidecar": "docker build -t appstrate-sidecar ./runtime-pi/sidecar",
    "db:generate": "cd packages/db && bunx drizzle-kit generate",
    "db:migrate": "cd packages/db && bunx drizzle-kit migrate",
    "docker:dev": "docker compose -f docker-compose.yml up -d",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "verify:openapi": "bun scripts/verify-openapi.ts"
  },
  "dependencies": {
    "@appstrate/validation": "^1.2.0"
  },
  "devDependencies": {
    "@readme/openapi-parser": "^5.5.0",
    "@redocly/openapi-core": "^2.19.1",
    "@types/bun": "latest",
    "prettier": "^3.8.1",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
