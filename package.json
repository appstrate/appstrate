{
  "name": "appstrate",
  "description": "[⚡️] Open-source Agent as a Service platform",
  "homepage": "https://github.com/appstrate/appstrate",
  "repository": {
    "type": "git",
    "url": "https://github.com/appstrate/appstrate.git"
  },
  "bugs": {
    "url": "https://github.com/appstrate/appstrate/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "docker",
    "automation",
    "llm"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-ai": "^0.66.0",
    "@readme/openapi-parser": "^5.5.0",
    "@redocly/openapi-core": "^2.19.1",
    "@types/bun": "latest",
    "@types/json-schema": "7.0.15",
    "@types/semver": "^7.7.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2",
    "typescript-eslint": "^8.55.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "bun test",
    "test:unit": "bun test apps/api/test/unit/",
    "test:watch": "bun test --watch apps/api/test/unit/",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:api": "cd e2e && npx playwright test --project=api",
    "test:e2e:ui": "cd e2e && npx playwright test --project=ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write \"apps/*/src/**\" \"packages/*/src/**\"",
    "format": "prettier --write \"apps/*/src/**\" \"packages/*/src/**\"",
    "format:check": "prettier --check \"apps/*/src/**\" \"packages/*/src/**\"",
    "check": "turbo typecheck && eslint . && prettier --check \"apps/*/src/**\" \"packages/*/src/**\" && bun scripts/verify-openapi.ts && bun scripts/build-system-packages.ts --check",
    "build-runtime": "docker build --platform linux/amd64 -t appstrate-pi ./runtime-pi",
    "build-sidecar": "docker build --platform linux/amd64 -t appstrate-sidecar ./runtime-pi/sidecar",
    "db:generate": "cd packages/db && bunx drizzle-kit generate",
    "db:migrate": "cd packages/db && bunx drizzle-kit migrate",
    "preinstall": "which bun > /dev/null 2>&1 || (echo '\\033[31mThis project requires Bun. Install it: https://bun.sh\\033[0m' && exit 1)",
    "setup": "bun scripts/setup.ts",
    "docker:dev": "docker compose -f docker-compose.dev.yml --profile full up -d",
    "docker:dev:minimal": "docker compose -f docker-compose.dev.yml --profile minimal up -d",
    "docker:dev:standard": "docker compose -f docker-compose.dev.yml --profile standard up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:prod": "docker compose --profile prod up -d",
    "docker:prod:down": "docker compose --profile prod down",
    "docker:prod:logs": "docker compose --profile prod logs -f",
    "docker:clean": "docker compose down -v && docker compose -f docker-compose.dev.yml down -v",
    "test:integration": "bun test apps/api/test/integration/",
    "db:studio": "cd packages/db && bunx drizzle-kit studio",
    "verify:openapi": "bun scripts/verify-openapi.ts",
    "openapi:baseline": "bun scripts/detect-breaking-changes.ts --update-baseline",
    "openapi:diff": "bun scripts/detect-breaking-changes.ts",
    "clean": "rm -rf node_modules/.cache .turbo apps/*/dist apps/web/.vite packages/*/dist coverage",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "runtime-pi",
    "runtime-pi/sidecar",
    "e2e"
  ],
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@afps-spec/schema": "^1.2.1",
    "@appstrate/core": "workspace:*",
    "@electric-sql/pglite": "^0.4.3",
    "ajv": "^8.18.0"
  },
  "patchedDependencies": {
    "@redocly/openapi-core@2.25.2": "patches/@redocly%2Fopenapi-core@2.25.2.patch"
  }
}
