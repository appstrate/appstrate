{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "tsconfig.*.json"]
    },
    "check": {
      "dependsOn": ["typecheck"]
    },
    "test": {
      "cache": false,
      "inputs": ["src/**", "test/**", "package.json", "bunfig.toml"]
    },
    "lint": {
      "inputs": ["src/**", "eslint.config.*"]
    }
  }
}
