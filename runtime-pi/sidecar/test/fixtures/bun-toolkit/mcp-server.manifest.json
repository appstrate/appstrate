{
  "manifest_version": "0.3",
  "name": "@appstrate/bun-toolkit-server",
  "version": "1.0.0",
  "type": "mcp-server",
  "schema_version": "0.1",
  "display_name": "Bun Toolkit Server",
  "description": "Reference mcp-server for a Bun-native MCP server. Zero-dependency, exercising bun:sqlite, Bun.CryptoHasher, Bun.password, crypto.randomUUID, and a runtime self-report.",
  "server": {
    "type": "node",
    "entry_point": "./server.ts",
    "mcp_config": { "command": "bun", "args": ["./server.ts"] }
  },
  "tools": [
    { "name": "kv_set" },
    { "name": "kv_get" },
    { "name": "kv_list" },
    { "name": "hash" },
    { "name": "password_hash" },
    { "name": "password_verify" },
    { "name": "uuid" },
    { "name": "system_info" },
    { "name": "fetch_echo" }
  ]
}
