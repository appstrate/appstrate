{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Integration Manifest",
  "description": "Appstrate integration manifest — AFPS 2.0 (packages/core/src/integration.ts). Cross-field rules (≥1 auth, oauth2 discovery, delivery, scope-catalog subset, per-tool auth-key) are enforced by the Zod superRefines and are not representable in JSON Schema.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "integration"
    },
    "display_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^2\\.(0|[1-9]\\d*)$"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "mcp_servers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "integrations": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "_meta": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "local"
            },
            "server": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
                },
                "version": {
                  "type": "string"
                },
                "vendored": {
                  "type": "boolean"
                }
              },
              "required": [
                "name",
                "version"
              ],
              "additionalProperties": {}
            }
          },
          "required": [
            "kind",
            "server"
          ],
          "additionalProperties": {}
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "remote"
            },
            "remote": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "minLength": 1
                },
                "transport": {
                  "type": "string",
                  "enum": [
                    "streamable-http",
                    "sse"
                  ]
                }
              },
              "required": [
                "url",
                "transport"
              ],
              "additionalProperties": {}
            }
          },
          "required": [
            "kind",
            "remote"
          ],
          "additionalProperties": {}
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "api"
            },
            "api": {
              "type": "object",
              "properties": {
                "upload_protocols": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "google-resumable",
                      "s3-multipart",
                      "tus",
                      "ms-resumable"
                    ]
                  }
                }
              },
              "additionalProperties": {}
            }
          },
          "required": [
            "kind",
            "api"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "auths": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "oauth2",
              "api_key",
              "basic",
              "custom"
            ]
          },
          "issuer": {
            "type": "string"
          },
          "authorization_endpoint": {
            "type": "string"
          },
          "token_endpoint": {
            "type": "string"
          },
          "userinfo_endpoint": {
            "type": "string"
          },
          "token_endpoint_auth_method": {
            "type": "string",
            "enum": [
              "client_secret_post",
              "client_secret_basic",
              "none"
            ]
          },
          "code_challenge_methods_supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "resource": {
            "type": "string"
          },
          "authorization_params": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "default_scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scope_catalog": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string"
                },
                "implies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "value",
                "label"
              ],
              "additionalProperties": {}
            }
          },
          "identity_claims": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "required_identity_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "credentials": {
            "type": "object",
            "properties": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "https://json-schema.org/draft/2020-12/schema"
                  },
                  {
                    "type": "object",
                    "required": [
                      "type",
                      "properties"
                    ],
                    "properties": {
                      "type": {
                        "const": "object"
                      }
                    }
                  }
                ]
              }
            },
            "required": [
              "schema"
            ],
            "additionalProperties": {}
          },
          "connect": {
            "type": "object",
            "properties": {
              "login": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "method": {
                        "type": "string",
                        "minLength": 1
                      },
                      "url": {
                        "type": "string",
                        "minLength": 1
                      },
                      "headers": {
                        "type": "object",
                        "propertyNames": {
                          "type": "string"
                        },
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "body": {
                        "type": "string"
                      },
                      "content_type": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "method",
                      "url"
                    ],
                    "additionalProperties": {}
                  },
                  "success_criteria": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "condition": {
                          "type": "string",
                          "minLength": 1
                        },
                        "context": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string",
                          "enum": [
                            "simple",
                            "regex",
                            "jsonpath",
                            "xpath"
                          ]
                        }
                      },
                      "required": [
                        "condition"
                      ],
                      "additionalProperties": {}
                    }
                  },
                  "outputs": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "anyOf": [
                        {
                          "type": "string",
                          "minLength": 1
                        },
                        {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "from"
                          ],
                          "additionalProperties": {}
                        }
                      ]
                    }
                  },
                  "expires_in_output": {
                    "type": "string"
                  },
                  "identity_outputs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "request"
                ],
                "additionalProperties": {}
              },
              "tool": {
                "type": "object",
                "properties": {},
                "additionalProperties": {}
              },
              "limits": {
                "type": "object",
                "properties": {
                  "request_timeout_ms": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "max_response_bytes": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "additionalProperties": {}
              }
            },
            "additionalProperties": {}
          },
          "delivery": {
            "type": "object",
            "properties": {
              "http": {
                "type": "object",
                "properties": {
                  "in": {
                    "type": "string",
                    "enum": [
                      "header",
                      "query",
                      "cookie"
                    ]
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "prefix": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string",
                    "minLength": 1
                  },
                  "encoding": {
                    "type": "string",
                    "enum": [
                      "base64"
                    ]
                  },
                  "allow_server_override": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "in",
                  "name",
                  "value"
                ],
                "additionalProperties": {}
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "minLength": 1
                    },
                    "sensitive": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": {}
                }
              },
              "files": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "minLength": 1
                    },
                    "mode": {
                      "type": "string",
                      "pattern": "^0[0-7]{3}$"
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": {}
                }
              }
            },
            "additionalProperties": {}
          },
          "authorized_uris": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allow_all_uris": {
            "type": "boolean"
          }
        },
        "required": [
          "type",
          "delivery"
        ],
        "additionalProperties": {}
      }
    },
    "icon": {
      "type": "string"
    },
    "tools": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "required_scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_auth_key": {
            "type": "string"
          },
          "url_patterns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "pattern": {
                  "type": "string",
                  "minLength": 1
                },
                "methods": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "pattern"
              ],
              "additionalProperties": {}
            }
          }
        },
        "additionalProperties": {}
      }
    },
    "setup_guide": {
      "type": "object",
      "properties": {
        "callback_url_hint": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "label"
            ],
            "additionalProperties": {}
          }
        }
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "name",
    "version",
    "type",
    "source",
    "auths"
  ],
  "additionalProperties": {}
}
