{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Integration Manifest",
  "description": "Appstrate integration manifest — AFPS (packages/core/src/integration.ts). Cross-field rules (≥1 auth, oauth2 discovery, delivery, scope-catalog subset, per-tool auth-key) are enforced by the Zod superRefines and are not representable in JSON Schema.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "integration"
    },
    "display_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "long_description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "author": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "repository": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "directory": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "homepage": {
      "type": "string"
    },
    "documentation": {
      "type": "string"
    },
    "support": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "icons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "src": {
            "type": "string",
            "minLength": 1
          },
          "size": {
            "type": "string",
            "pattern": "^\\d+x\\d+$"
          },
          "theme": {
            "type": "string",
            "enum": [
              "light",
              "dark",
              "high-contrast"
            ]
          }
        },
        "required": [
          "src"
        ],
        "additionalProperties": {}
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "privacy_policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "darwin",
              "win32",
              "linux"
            ]
          }
        },
        "runtimes": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "clients": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.(0|[1-9]\\d*)$",
      "description": "AFPS schema version this manifest targets, in MAJOR.MINOR format (e.g. \"0.0\"). Distinct from the package \"version\" field, which uses full MAJOR.MINOR.PATCH semver."
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "mcp_servers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "integrations": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "_meta": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^(?!(?:mcp|modelcontextprotocol)(?:[./]|$))(?:[a-z0-9-]+(?:\\.[a-z0-9-]+)+\\/)?[A-Za-z0-9._-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "local"
            },
            "server": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
                },
                "version": {
                  "type": "string"
                },
                "vendored": {
                  "type": "boolean"
                }
              },
              "required": [
                "name",
                "version"
              ],
              "additionalProperties": {}
            }
          },
          "required": [
            "kind",
            "server"
          ],
          "additionalProperties": {}
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "remote"
            },
            "remote": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "transport": {
                  "type": "string",
                  "enum": [
                    "streamable-http",
                    "sse"
                  ]
                }
              },
              "required": [
                "url",
                "transport"
              ],
              "additionalProperties": {}
            }
          },
          "required": [
            "kind",
            "remote"
          ],
          "additionalProperties": {}
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "none"
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "auths": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "oauth2",
              "api_key",
              "basic",
              "mtls",
              "custom"
            ]
          },
          "issuer": {
            "type": "string",
            "format": "uri"
          },
          "authorization_endpoint": {
            "type": "string",
            "format": "uri"
          },
          "token_endpoint": {
            "type": "string",
            "format": "uri"
          },
          "userinfo_endpoint": {
            "type": "string",
            "format": "uri"
          },
          "token_endpoint_auth_method": {
            "type": "string",
            "enum": [
              "client_secret_basic",
              "client_secret_post",
              "client_secret_jwt",
              "private_key_jwt",
              "tls_client_auth",
              "self_signed_tls_client_auth",
              "none"
            ]
          },
          "code_challenge_methods_supported": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "resource": {
            "type": "string"
          },
          "authorization_params": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "default_scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scope_catalog": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string"
                },
                "implies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "value",
                "label"
              ],
              "additionalProperties": {}
            }
          },
          "identity_claims": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "required_identity_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "credentials": {
            "type": "object",
            "properties": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "https://json-schema.org/draft/2020-12/schema"
                  },
                  {
                    "type": "object",
                    "required": [
                      "type",
                      "properties"
                    ],
                    "properties": {
                      "type": {
                        "const": "object"
                      }
                    }
                  }
                ]
              }
            },
            "required": [
              "schema"
            ],
            "additionalProperties": {}
          },
          "connect": {
            "type": "object",
            "properties": {
              "login": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "method": {
                        "type": "string",
                        "minLength": 1
                      },
                      "url": {
                        "type": "string",
                        "minLength": 1
                      },
                      "headers": {
                        "type": "object",
                        "propertyNames": {
                          "type": "string"
                        },
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "body": {
                        "type": "string"
                      },
                      "content_type": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "method",
                      "url"
                    ],
                    "additionalProperties": {}
                  },
                  "success_criteria": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "condition": {
                          "type": "string",
                          "minLength": 1
                        },
                        "context": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string",
                          "enum": [
                            "simple",
                            "regex",
                            "jsonpath",
                            "xpath"
                          ]
                        }
                      },
                      "required": [
                        "condition"
                      ],
                      "additionalProperties": {}
                    }
                  },
                  "outputs": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "anyOf": [
                        {
                          "type": "string",
                          "minLength": 1
                        },
                        {
                          "type": "object",
                          "properties": {
                            "context": {
                              "type": "string",
                              "minLength": 1
                            },
                            "selector": {
                              "type": "string",
                              "minLength": 1
                            },
                            "type": {
                              "type": "string",
                              "enum": [
                                "jsonpath",
                                "xpath",
                                "jsonpointer"
                              ]
                            }
                          },
                          "required": [
                            "context",
                            "selector",
                            "type"
                          ],
                          "additionalProperties": {}
                        },
                        {
                          "oneOf": [
                            {
                              "type": "object",
                              "properties": {
                                "from": {
                                  "type": "string",
                                  "const": "cookie"
                                },
                                "name": {
                                  "type": "string",
                                  "minLength": 1
                                }
                              },
                              "required": [
                                "from",
                                "name"
                              ],
                              "additionalProperties": {}
                            },
                            {
                              "type": "object",
                              "properties": {
                                "from": {
                                  "type": "string",
                                  "const": "jwt"
                                },
                                "token": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "path": {
                                  "type": "string",
                                  "minLength": 1
                                }
                              },
                              "required": [
                                "from",
                                "token",
                                "path"
                              ],
                              "additionalProperties": {}
                            },
                            {
                              "type": "object",
                              "properties": {
                                "from": {
                                  "type": "string",
                                  "const": "regex"
                                },
                                "source": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "pattern": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "group": {
                                  "type": "integer",
                                  "minimum": 0,
                                  "maximum": 9007199254740991
                                }
                              },
                              "required": [
                                "from",
                                "source",
                                "pattern"
                              ],
                              "additionalProperties": {}
                            }
                          ]
                        }
                      ]
                    }
                  },
                  "expires_in_output": {
                    "type": "string"
                  },
                  "identity_outputs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "request"
                ],
                "additionalProperties": {}
              },
              "tool": {
                "type": "object",
                "properties": {},
                "additionalProperties": {}
              },
              "limits": {
                "type": "object",
                "properties": {
                  "request_timeout_ms": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "max_response_bytes": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "additionalProperties": {}
              }
            },
            "additionalProperties": {}
          },
          "delivery": {
            "type": "object",
            "properties": {
              "http": {
                "type": "object",
                "properties": {
                  "in": {
                    "type": "string",
                    "enum": [
                      "header",
                      "query",
                      "cookie"
                    ]
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "prefix": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string",
                    "minLength": 1
                  },
                  "encoding": {
                    "type": "string",
                    "enum": [
                      "base64"
                    ]
                  },
                  "allow_server_override": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "in",
                  "name",
                  "value"
                ],
                "additionalProperties": {}
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "minLength": 1
                    },
                    "sensitive": {
                      "type": "boolean"
                    },
                    "user_config_key": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": {}
                }
              },
              "files": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "minLength": 1
                    },
                    "mode": {
                      "type": "string",
                      "pattern": "^0[0-7]{3}$"
                    }
                  },
                  "required": [
                    "value"
                  ],
                  "additionalProperties": {}
                }
              }
            },
            "additionalProperties": {}
          },
          "authorized_uris": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allow_all_uris": {
            "type": "boolean"
          },
          "callback_url_hint": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "delivery"
        ],
        "additionalProperties": {}
      }
    },
    "tools_policy": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "required_scopes": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            },
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "additionalProperties": {}
      }
    },
    "hidden_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allow_undeclared_tools": {
      "type": "boolean"
    },
    "setup_guide": {
      "type": "object",
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "label"
            ],
            "additionalProperties": {}
          }
        }
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "name",
    "version",
    "type",
    "source",
    "auths"
  ],
  "additionalProperties": {}
}
