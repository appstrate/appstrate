{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Integration Manifest",
  "description": "Appstrate integration manifest — derived from the canonical Zod schema (packages/core/src/integration.ts). Cross-field rules (server || apiCall, per-auth delivery) are enforced by the Zod superRefines and are not representable in JSON Schema.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifestVersion": {
      "type": "string",
      "pattern": "^1\\.(0|[1-9]\\d*)$"
    },
    "type": {
      "type": "string",
      "const": "integration"
    },
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "author": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      ]
    },
    "repository": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": false
        }
      ]
    },
    "privacyPolicy": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "icon": {
      "type": "string"
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "afps": {
          "type": "string"
        },
        "mcp": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "_meta": {
      "type": "object",
      "properties": {},
      "additionalProperties": {}
    },
    "server": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "node",
            "bun",
            "python",
            "uv",
            "binary",
            "docker",
            "http",
            "npx",
            "uvx"
          ]
        },
        "entryPoint": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "registryType": {
                  "type": "string",
                  "const": "oci"
                },
                "identifier": {
                  "type": "string",
                  "minLength": 1
                },
                "digest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "registryBaseUrl": {
                  "type": "string"
                }
              },
              "required": [
                "registryType",
                "identifier",
                "digest"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "registryType": {
                  "type": "string",
                  "const": "npm"
                },
                "identifier": {
                  "type": "string",
                  "minLength": 1
                },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "registryBaseUrl": {
                  "type": "string"
                }
              },
              "required": [
                "registryType",
                "identifier",
                "version"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "registryType": {
                  "type": "string",
                  "const": "pypi"
                },
                "identifier": {
                  "type": "string",
                  "minLength": 1
                },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "registryBaseUrl": {
                  "type": "string"
                }
              },
              "required": [
                "registryType",
                "identifier",
                "version"
              ],
              "additionalProperties": false
            }
          ]
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "auths": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "oauth2",
              "api_key",
              "basic",
              "custom"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "authorizationUrl": {
            "type": "string"
          },
          "tokenUrl": {
            "type": "string"
          },
          "refreshUrl": {
            "type": "string"
          },
          "userinfoUrl": {
            "type": "string"
          },
          "audience": {
            "type": "string"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scopeSeparator": {
            "type": "string"
          },
          "pkceEnabled": {
            "type": "boolean"
          },
          "authorizationParams": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "tokenAuthMethod": {
            "type": "string",
            "enum": [
              "client_secret_post",
              "client_secret_basic",
              "none"
            ]
          },
          "extractTokenIdentity": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "requiredIdentityClaims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authorizedUris": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowAllUris": {
            "type": "boolean"
          },
          "availableScopes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string"
                },
                "implies": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "required": [
                "value",
                "label"
              ],
              "additionalProperties": false
            }
          },
          "credentials": {
            "type": "object",
            "properties": {
              "schema": {
                "type": "object",
                "properties": {},
                "additionalProperties": {}
              }
            },
            "required": [
              "schema"
            ],
            "additionalProperties": false
          },
          "connect": {
            "type": "object",
            "properties": {
              "login": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "method": {
                        "type": "string",
                        "enum": [
                          "GET",
                          "POST",
                          "PUT",
                          "PATCH",
                          "DELETE"
                        ]
                      },
                      "url": {
                        "type": "string",
                        "minLength": 1
                      },
                      "headers": {
                        "type": "object",
                        "propertyNames": {
                          "type": "string"
                        },
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "body": {
                        "type": "string"
                      },
                      "contentType": {
                        "type": "string",
                        "enum": [
                          "application/x-www-form-urlencoded",
                          "application/json"
                        ]
                      }
                    },
                    "required": [
                      "method",
                      "url"
                    ],
                    "additionalProperties": false
                  },
                  "okStatus": {
                    "type": "array",
                    "items": {
                      "type": "integer",
                      "minimum": 100,
                      "maximum": 599
                    }
                  },
                  "extract": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "oneOf": [
                        {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "string",
                              "const": "json"
                            },
                            "path": {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 256
                            }
                          },
                          "required": [
                            "from",
                            "path"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "string",
                              "const": "jwt"
                            },
                            "token": {
                              "type": "string",
                              "minLength": 1
                            },
                            "path": {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 256
                            }
                          },
                          "required": [
                            "from",
                            "token",
                            "path"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "string",
                              "const": "regex"
                            },
                            "pattern": {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 256
                            },
                            "group": {
                              "type": "integer",
                              "minimum": 0,
                              "maximum": 20
                            }
                          },
                          "required": [
                            "from",
                            "pattern"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "string",
                              "const": "header"
                            },
                            "name": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "from",
                            "name"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "string",
                              "const": "cookie"
                            },
                            "name": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "from",
                            "name"
                          ],
                          "additionalProperties": false
                        }
                      ]
                    }
                  },
                  "output": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "request"
                ],
                "additionalProperties": false
              },
              "limits": {
                "type": "object",
                "properties": {
                  "stepTimeoutMs": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 60000
                  },
                  "maxResponseBytes": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5000000
                  }
                },
                "additionalProperties": false
              },
              "expiresInOutput": {
                "type": "string"
              },
              "identityOutputs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tool": {
                "type": "string",
                "minLength": 1
              },
              "runAt": {
                "type": "string",
                "enum": [
                  "link",
                  "run-start"
                ]
              },
              "reauthOn": {
                "maxItems": 8,
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 100,
                  "maximum": 599
                }
              },
              "persistLoginSecret": {
                "type": "boolean"
              },
              "produces": {
                "maxItems": 32,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "delivery": {
            "type": "object",
            "properties": {
              "http": {
                "type": "object",
                "properties": {
                  "headerName": {
                    "type": "string",
                    "minLength": 1
                  },
                  "headerPrefix": {
                    "type": "string"
                  },
                  "valueFrom": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 1
                      },
                      {
                        "type": "object",
                        "properties": {
                          "template": {
                            "type": "string",
                            "minLength": 1
                          },
                          "encoding": {
                            "type": "string",
                            "enum": [
                              "base64"
                            ]
                          }
                        },
                        "required": [
                          "template"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  },
                  "allowServerOverride": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "from": {
                      "type": "string",
                      "minLength": 1
                    },
                    "sensitive": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "from"
                  ],
                  "additionalProperties": false
                }
              },
              "files": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "from": {
                      "type": "string",
                      "minLength": 1
                    },
                    "mode": {
                      "type": "string",
                      "pattern": "^0[0-7]{3}$"
                    }
                  },
                  "required": [
                    "from"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "type",
          "authorizedUris",
          "delivery"
        ],
        "additionalProperties": false
      }
    },
    "tools": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z_][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "requiredScopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requiredAuthKey": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "urlPatterns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "pattern": {
                  "type": "string",
                  "minLength": 1
                },
                "methods": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "GET",
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "HEAD",
                      "OPTIONS"
                    ]
                  }
                }
              },
              "required": [
                "pattern"
              ],
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "apiCall": {
      "type": "object",
      "properties": {
        "authKey": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "uploadProtocols": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "google-resumable",
              "s3-multipart",
              "tus",
              "ms-resumable"
            ]
          }
        }
      },
      "required": [
        "authKey"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "manifestVersion",
    "type",
    "name",
    "version",
    "displayName"
  ],
  "additionalProperties": false
}
