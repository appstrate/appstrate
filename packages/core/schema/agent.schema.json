{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Agent Manifest",
  "description": "Appstrate agent manifest — extends AFPS agent.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "agent"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^2\\.(0|[1-9]\\d*)$"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "mcp_servers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "integrations": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "_meta": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    },
    "author": {
      "type": "string"
    },
    "integrations_configuration": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z_][a-z0-9_]*$"
            }
          }
        },
        "additionalProperties": {}
      }
    },
    "input": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "file_constraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "max_size": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "ui_hints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "property_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "file_constraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "max_size": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "ui_hints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "property_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "file_constraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "max_size": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "ui_hints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "property_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "timeout": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "runtime_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "output",
          "log",
          "note",
          "pin",
          "report"
        ]
      }
    }
  },
  "required": [
    "name",
    "version",
    "type",
    "display_name",
    "schema_version"
  ],
  "additionalProperties": {}
}
