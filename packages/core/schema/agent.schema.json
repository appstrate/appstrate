{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Agent Manifest",
  "description": "Appstrate agent manifest — extends AFPS agent.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "agent"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.(0|[1-9]\\d*)$"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "tools": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "providers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "providersConfiguration": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": {}
      }
    },
    "input": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "fileConstraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "maxSize": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "uiHints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "propertyOrder": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "fileConstraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "maxSize": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "uiHints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "propertyOrder": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "fileConstraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "maxSize": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "uiHints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "propertyOrder": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "timeout": {
      "type": "number",
      "exclusiveMinimum": 0
    }
  },
  "required": [
    "name",
    "version",
    "type",
    "displayName",
    "schemaVersion",
    "author"
  ],
  "additionalProperties": {}
}
