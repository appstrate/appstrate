{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Agent Manifest",
  "description": "Appstrate agent manifest — extends AFPS agent.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "agent"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "long_description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "author": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "repository": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "directory": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "homepage": {
      "type": "string"
    },
    "documentation": {
      "type": "string"
    },
    "support": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "icons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "src": {
            "type": "string",
            "minLength": 1
          },
          "size": {
            "type": "string",
            "pattern": "^\\d+x\\d+$"
          },
          "theme": {
            "type": "string",
            "enum": [
              "light",
              "dark",
              "high-contrast"
            ]
          }
        },
        "required": [
          "src"
        ],
        "additionalProperties": {}
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "privacy_policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "darwin",
              "win32",
              "linux"
            ]
          }
        },
        "runtimes": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "clients": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.(0|[1-9]\\d*)$",
      "description": "AFPS schema version this manifest targets, in MAJOR.MINOR format (e.g. \"0.0\"). Distinct from the package \"version\" field, which uses full MAJOR.MINOR.PATCH semver."
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "mcp_servers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "integrations": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "_meta": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^(?!(?:mcp|modelcontextprotocol)(?:[./]|$))(?:[a-z0-9-]+(?:\\.[a-z0-9-]+)+\\/)?[A-Za-z0-9._-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    },
    "integrations_configuration": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tools": {
            "anyOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "string",
                "const": "*"
              }
            ]
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "auth_key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "additionalProperties": {}
      }
    },
    "input": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "file_constraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "max_size": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "ui_hints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "property_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "_meta": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^(?!(?:mcp|modelcontextprotocol)(?:[./]|$))(?:[a-z0-9-]+(?:\\.[a-z0-9-]+)+\\/)?[A-Za-z0-9._-]+$"
          },
          "additionalProperties": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "file_constraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "max_size": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "ui_hints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "property_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "_meta": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^(?!(?:mcp|modelcontextprotocol)(?:[./]|$))(?:[a-z0-9-]+(?:\\.[a-z0-9-]+)+\\/)?[A-Za-z0-9._-]+$"
          },
          "additionalProperties": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "schema": {
          "allOf": [
            {
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "type": "object",
              "required": [
                "type",
                "properties"
              ],
              "properties": {
                "type": {
                  "const": "object"
                }
              }
            }
          ]
        },
        "file_constraints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "string"
              },
              "max_size": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": {}
          }
        },
        "ui_hints": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "placeholder": {
                "type": "string"
              }
            },
            "additionalProperties": {}
          }
        },
        "property_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "_meta": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^(?!(?:mcp|modelcontextprotocol)(?:[./]|$))(?:[a-z0-9-]+(?:\\.[a-z0-9-]+)+\\/)?[A-Za-z0-9._-]+$"
          },
          "additionalProperties": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        }
      },
      "required": [
        "schema"
      ],
      "additionalProperties": false
    },
    "timeout": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "runtime_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "output",
          "log",
          "note",
          "pin",
          "report",
          "publish_document"
        ]
      }
    }
  },
  "required": [
    "name",
    "version",
    "type",
    "display_name",
    "schema_version"
  ],
  "additionalProperties": {}
}
