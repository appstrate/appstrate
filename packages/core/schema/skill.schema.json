{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Skill Manifest",
  "description": "Appstrate skill manifest — AFPS skill with relaxed optional metadata.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "skill"
    },
    "display_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "long_description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "author": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "repository": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "directory": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": {}
        }
      ]
    },
    "homepage": {
      "type": "string"
    },
    "documentation": {
      "type": "string"
    },
    "support": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "icons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "src": {
            "type": "string",
            "minLength": 1
          },
          "size": {
            "type": "string",
            "pattern": "^\\d+x\\d+$"
          },
          "theme": {
            "type": "string",
            "enum": [
              "light",
              "dark",
              "high-contrast"
            ]
          }
        },
        "required": [
          "src"
        ],
        "additionalProperties": {}
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "privacy_policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "darwin",
              "win32",
              "linux"
            ]
          }
        },
        "runtimes": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "clients": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.(0|[1-9]\\d*)$",
      "description": "AFPS schema version this manifest targets, in MAJOR.MINOR format (e.g. \"0.0\"). Distinct from the package \"version\" field, which uses full MAJOR.MINOR.PATCH semver."
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "mcp_servers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "integrations": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "_meta": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^(?!(?:mcp|modelcontextprotocol)(?:[./]|$))(?:[a-z0-9-]+(?:\\.[a-z0-9-]+)+\\/)?[A-Za-z0-9._-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    }
  },
  "required": [
    "name",
    "version",
    "type"
  ],
  "additionalProperties": {}
}
