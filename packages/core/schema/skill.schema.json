{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Skill Manifest",
  "description": "Appstrate skill manifest — AFPS skill with no extensions.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "skill"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.(0|[1-9]\\d*)$"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "tools": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "providers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "name",
    "version",
    "type"
  ],
  "additionalProperties": {}
}
