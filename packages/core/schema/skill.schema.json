{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appstrate Skill Manifest",
  "description": "Appstrate skill manifest — AFPS 2.0 skill with relaxed optional metadata.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "skill"
    },
    "display_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^2\\.(0|[1-9]\\d*)$"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "mcp_servers": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "integrations": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^@[a-z0-9]([a-z0-9-]*[a-z0-9])?\\/[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {}
    },
    "_meta": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    }
  },
  "required": [
    "name",
    "version",
    "type"
  ],
  "additionalProperties": {}
}
