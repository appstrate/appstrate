{
  "name": "@appstrate/core",
  "version": "2.10.5",
  "description": "Shared validation, storage, and utility library for Appstrate packages",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "author": "Appstrate <hello@appstrate.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/appstrate/appstrate.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/appstrate/appstrate/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/appstrate/appstrate/issues"
  },
  "keywords": [
    "appstrate",
    "validation",
    "zod",
    "manifest",
    "afps",
    "semver",
    "ssrf",
    "s3-storage"
  ],
  "files": [
    "src",
    "schema",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    "./logger": "./src/logger.ts",
    "./env": "./src/env.ts",
    "./storage": "./src/storage.ts",
    "./storage-s3": "./src/storage-s3.ts",
    "./storage-fs": "./src/storage-fs.ts",
    "./errors": "./src/errors.ts",
    "./validation": "./src/validation.ts",
    "./zip": "./src/zip.ts",
    "./naming": "./src/naming.ts",
    "./dependencies": "./src/dependencies.ts",
    "./integrity": "./src/integrity.ts",
    "./semver": "./src/semver.ts",
    "./dist-tags": "./src/dist-tags.ts",
    "./version-policy": "./src/version-policy.ts",
    "./system-packages": "./src/system-packages.ts",
    "./ssrf": "./src/ssrf.ts",
    "./schemas": "./src/schemas.ts",
    "./form": "./src/form.ts",
    "./module": "./src/module.ts"
  },
  "dependencies": {
    "@afps-spec/schema": "^1.2.1",
    "fflate": "^0.8.0",
    "pino": "^10.3.1",
    "semver": "^7.7.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3",
    "hono": "^4.12.9",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit",
    "test": "bun test",
    "generate:schemas": "bun scripts/generate-schemas.ts"
  }
}
