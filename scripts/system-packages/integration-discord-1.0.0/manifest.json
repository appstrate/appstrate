{
  "name": "@appstrate/discord",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Discord (API)",
  "description": "Communication platform for communities and teams",
  "keywords": ["social-media", "messaging", "community"],
  "license": "Apache-2.0",
  "icon": "discord",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://discord.com/oauth2/authorize",
      "token_endpoint": "https://discord.com/api/v10/oauth2/token",
      "default_scopes": ["identify"],
      "token_endpoint_auth_method": "client_secret_basic",
      "scope_catalog": [
        {
          "value": "identify",
          "label": "Read user profile (id, username, avatar)"
        },
        {
          "value": "email",
          "label": "Read user email address"
        },
        {
          "value": "guilds",
          "label": "List user's guilds (servers)"
        },
        {
          "value": "guilds.join",
          "label": "Add user to a guild"
        },
        {
          "value": "guilds.members.read",
          "label": "Read user's guild member info"
        },
        {
          "value": "connections",
          "label": "View user's linked accounts"
        },
        {
          "value": "bot",
          "label": "Add bot to a guild"
        },
        {
          "value": "webhook.incoming",
          "label": "Create incoming webhooks"
        },
        {
          "value": "applications.commands",
          "label": "Register slash commands"
        },
        {
          "value": "messages.read",
          "label": "Read messages in channels"
        }
      ],
      "authorized_uris": ["https://discord.com/api/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
