{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/fathom",
  "version": "1.0.0",
  "displayName": "Fathom",
  "description": "AI meeting recorder with transcripts and summaries",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "https://cdn.simpleicons.org/fathom",
  "keywords": ["meetings", "productivity"],
  "apiCall": {},
  "auths": {
    "primary": {
      "type": "api_key",
      "required": true,
      "authorizedUris": ["https://api.fathom.ai/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Fathom API key (from Settings)"
            }
          },
          "required": ["api_key"]
        }
      },
      "delivery": {
        "http": {
          "headerName": "X-Api-Key",
          "valueFrom": "api_key"
        }
      }
    }
  }
}
