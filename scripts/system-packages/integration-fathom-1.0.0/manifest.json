{
  "name": "@appstrate/fathom",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Fathom (API)",
  "description": "AI meeting recorder with transcripts and summaries",
  "keywords": ["meetings", "productivity"],
  "license": "Apache-2.0",
  "icon": "https://cdn.simpleicons.org/fathom",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "authorized_uris": ["https://api.fathom.ai/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Fathom API key (from Settings)"
            }
          },
          "required": ["api_key"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "X-Api-Key",
          "value": "{$credential.api_key}"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
