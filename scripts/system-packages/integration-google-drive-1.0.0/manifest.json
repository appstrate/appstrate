{
  "name": "@appstrate/google-drive",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Google Drive (API)",
  "description": "Cloud file storage and synchronization",
  "keywords": ["storage", "productivity"],
  "license": "Apache-2.0",
  "icon": "logos:google-drive",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "issuer": "https://accounts.google.com",
      "default_scopes": ["openid", "email", "https://www.googleapis.com/auth/drive.file"],
      "authorization_params": {
        "access_type": "offline",
        "prompt": "consent"
      },
      "token_endpoint_auth_method": "client_secret_post",
      "identity_claims": {
        "accountId": "$.email",
        "sub": "$.sub",
        "email": "$.email",
        "name": "$.name",
        "picture": "$.picture"
      },
      "scope_catalog": [
        {
          "value": "openid",
          "label": "Identity (OpenID)"
        },
        {
          "value": "email",
          "label": "Email address"
        },
        {
          "value": "https://www.googleapis.com/auth/drive.file",
          "label": "Per-file access (recommended)"
        },
        {
          "value": "https://www.googleapis.com/auth/drive.readonly",
          "label": "Read-only access"
        },
        {
          "value": "https://www.googleapis.com/auth/drive",
          "label": "Full access"
        },
        {
          "value": "https://www.googleapis.com/auth/drive.metadata.readonly",
          "label": "Read metadata only"
        },
        {
          "value": "https://www.googleapis.com/auth/drive.appdata",
          "label": "App data folder"
        },
        {
          "value": "https://www.googleapis.com/auth/drive.photos.readonly",
          "label": "Read photos/videos"
        }
      ],
      "authorized_uris": [
        "https://www.googleapis.com/drive/**",
        "https://www.googleapis.com/upload/drive/**"
      ],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {
          "upload_protocols": ["google-resumable"]
        }
      }
    }
  }
}
