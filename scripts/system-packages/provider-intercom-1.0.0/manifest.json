{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/intercom",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Intercom",
  "description": "Customer messaging and support platform",
  "iconUrl": "intercom",
  "categories": ["customer-support", "messaging"],
  "docsUrl": "https://developers.intercom.com/docs/references/rest-api/api.intercom.io/",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://app.intercom.com/oauth",
      "tokenUrl": "https://api.intercom.io/auth/eagle/token",
      "defaultScopes": [],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.intercom.io/**"],
    "availableScopes": []
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Create an Intercom developer app",
        "url": "https://app.intercom.com/a/apps/_/developer-hub"
      },
      { "label": "Configure OAuth redirect URI" },
      { "label": "Copy your Client ID and Client Secret" }
    ]
  },
  "schemaVersion": "1.1"
}
