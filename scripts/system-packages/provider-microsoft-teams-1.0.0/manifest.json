{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/microsoft-teams",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Microsoft Teams",
  "description": "Team collaboration and messaging platform by Microsoft",
  "iconUrl": "microsoftteams",
  "categories": ["messaging", "collaboration"],
  "docsUrl": "https://learn.microsoft.com/en-us/graph/api/resources/teams-api-overview",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "refreshUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "defaultScopes": [
        "Team.ReadBasic.All",
        "Channel.ReadBasic.All",
        "Chat.Read",
        "User.Read",
        "offline_access"
      ],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://graph.microsoft.com/**"],
    "availableScopes": [
      { "value": "Team.ReadBasic.All", "label": "Read team names and descriptions" },
      { "value": "Channel.ReadBasic.All", "label": "Read channel names and descriptions" },
      { "value": "ChannelMessage.Read.All", "label": "Read channel messages" },
      { "value": "Chat.Read", "label": "Read user chats" },
      { "value": "Chat.ReadWrite", "label": "Read and write user chats" },
      { "value": "ChatMessage.Send", "label": "Send chat messages" },
      { "value": "ChannelMessage.Send", "label": "Send channel messages" },
      { "value": "User.Read", "label": "Read user profile" },
      { "value": "User.ReadBasic.All", "label": "Read all users' basic info" },
      { "value": "offline_access", "label": "Maintain access (refresh tokens)" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Register an application in Azure AD",
        "url": "https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade"
      },
      { "label": "Add Microsoft Graph delegated permissions for Teams" },
      { "label": "Create a client secret under Certificates & secrets" }
    ]
  },
  "schemaVersion": "1.0"
}
