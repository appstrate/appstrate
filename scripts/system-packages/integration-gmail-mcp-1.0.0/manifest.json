{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/gmail-mcp",
  "version": "1.0.0",
  "displayName": "Gmail",
  "description": "Gmail MCP integration — exposes typed tools (list_messages, get_message, search_messages) backed by the Gmail REST API. OAuth2 access tokens are injected transparently by the sidecar's MITM proxy on every upstream call; the bundle never reads the credential itself. Pure-stdlib Python (urllib + json) — zero pip deps.",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "iconUrl": "gmail",
  "categories": ["email", "productivity"],
  "server": {
    "type": "python",
    "entryPoint": "./server.py"
  },
  "transport": {
    "type": "stdio"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "refreshUrl": "https://oauth2.googleapis.com/token",
      "scopes": ["https://www.googleapis.com/auth/gmail.readonly"],
      "scopeSeparator": " ",
      "tokenAuthMethod": "client_secret_post",
      "authorizedUris": ["https://gmail.googleapis.com/**", "https://www.googleapis.com/gmail/**"],
      "availableScopes": [
        {
          "value": "https://www.googleapis.com/auth/gmail.readonly",
          "label": "Read-only access",
          "description": "List, read, and search messages and labels."
        },
        {
          "value": "https://www.googleapis.com/auth/gmail.metadata",
          "label": "Metadata only",
          "description": "Read headers, labels, and metadata without message bodies."
        },
        {
          "value": "https://www.googleapis.com/auth/gmail.send",
          "label": "Send messages",
          "description": "Send mail as the user (no read access)."
        },
        {
          "value": "https://www.googleapis.com/auth/gmail.compose",
          "label": "Compose drafts & send",
          "description": "Create, read, update, and send drafts."
        },
        {
          "value": "https://www.googleapis.com/auth/gmail.modify",
          "label": "Read & write (no delete)",
          "description": "All Gmail operations except permanent deletion."
        },
        {
          "value": "https://www.googleapis.com/auth/gmail.labels",
          "label": "Manage labels"
        },
        {
          "value": "https://www.googleapis.com/auth/gmail.insert",
          "label": "Insert messages"
        },
        {
          "value": "https://www.googleapis.com/auth/gmail.settings.basic",
          "label": "Manage basic settings"
        },
        {
          "value": "https://mail.google.com/",
          "label": "Full mailbox access"
        }
      ],
      "delivery": {
        "http": {}
      }
    }
  },
  "tools": {
    "list_messages": {
      "requiredScopes": ["https://www.googleapis.com/auth/gmail.readonly"],
      "urlPatterns": [
        {
          "pattern": "https://gmail.googleapis.com/gmail/v1/users/*/messages",
          "methods": ["GET"]
        }
      ]
    },
    "get_message": {
      "requiredScopes": ["https://www.googleapis.com/auth/gmail.readonly"],
      "urlPatterns": [
        {
          "pattern": "https://gmail.googleapis.com/gmail/v1/users/*/messages/*",
          "methods": ["GET"]
        }
      ]
    },
    "search_messages": {
      "requiredScopes": ["https://www.googleapis.com/auth/gmail.readonly"],
      "urlPatterns": [
        {
          "pattern": "https://gmail.googleapis.com/gmail/v1/users/*/messages",
          "methods": ["GET"]
        },
        {
          "pattern": "https://gmail.googleapis.com/gmail/v1/users/*/messages/*",
          "methods": ["GET"]
        }
      ]
    }
  }
}
