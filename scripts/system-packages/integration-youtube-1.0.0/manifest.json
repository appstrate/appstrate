{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/youtube",
  "version": "1.0.0",
  "displayName": "YouTube (API)",
  "description": "Video sharing and streaming platform by Google",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "youtube",
  "keywords": ["social-media", "video", "marketing"],
  "apiCall": {
    "authKey": "primary"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": [
        "https://www.googleapis.com/youtube/**",
        "https://youtube.googleapis.com/**",
        "https://www.googleapis.com/upload/youtube/**"
      ],
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "refreshUrl": "https://oauth2.googleapis.com/token",
      "scopes": ["https://www.googleapis.com/auth/youtube.readonly"],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post",
      "availableScopes": [
        {
          "value": "https://www.googleapis.com/auth/youtube.readonly",
          "label": "Read-only access (videos, channels, playlists)"
        },
        {
          "value": "https://www.googleapis.com/auth/youtube",
          "label": "Full access (manage account)"
        },
        {
          "value": "https://www.googleapis.com/auth/youtube.upload",
          "label": "Upload videos"
        },
        {
          "value": "https://www.googleapis.com/auth/youtube.force-ssl",
          "label": "Manage videos, comments, captions (SSL required)"
        },
        {
          "value": "https://www.googleapis.com/auth/youtubepartner",
          "label": "YouTube Partner (content & rights management)"
        },
        {
          "value": "https://www.googleapis.com/auth/youtube.channel-memberships.creator",
          "label": "Read channel memberships"
        }
      ],
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "access_token"
        }
      }
    }
  }
}
