{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/microsoft-outlook",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Microsoft Outlook",
  "description": "Email and calendar service by Microsoft",
  "iconUrl": "microsoftoutlook",
  "categories": ["email", "productivity"],
  "docsUrl": "https://learn.microsoft.com/en-us/graph/api/resources/mail-api-overview",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "refreshUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "defaultScopes": ["Mail.Read", "User.Read", "offline_access"],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://graph.microsoft.com/**"],
    "availableScopes": [
      { "value": "Mail.Read", "label": "Read user mail" },
      { "value": "Mail.ReadWrite", "label": "Read and write user mail" },
      { "value": "Mail.Send", "label": "Send mail" },
      { "value": "Contacts.Read", "label": "Read contacts" },
      { "value": "Contacts.ReadWrite", "label": "Read and write contacts" },
      { "value": "Calendars.Read", "label": "Read calendars" },
      { "value": "Calendars.ReadWrite", "label": "Read and write calendars" },
      { "value": "User.Read", "label": "Read user profile" },
      { "value": "offline_access", "label": "Maintain access (refresh tokens)" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Register an application in Azure AD",
        "url": "https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade"
      },
      {
        "label": "Add Microsoft Graph delegated permissions (Mail.Read, User.Read, offline_access)"
      },
      { "label": "Create a client secret under Certificates & secrets" }
    ]
  },
  "schemaVersion": "1.0"
}
