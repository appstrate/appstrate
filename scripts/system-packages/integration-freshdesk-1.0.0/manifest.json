{
  "name": "@appstrate/freshdesk",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Freshdesk (API)",
  "description": "Customer support and helpdesk ticketing platform",
  "keywords": ["crm", "support", "customer-service"],
  "license": "Apache-2.0",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "authorized_uris": ["https://*.freshdesk.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Freshdesk API key (found in Profile Settings > API Key)"
            },
            "subdomain": {
              "type": "string",
              "description": "Your Freshdesk subdomain (e.g. 'mycompany' from mycompany.freshdesk.com)"
            }
          },
          "required": ["api_key", "subdomain"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Basic",
          "value": "{$credential.api_key}:X",
          "encoding": "base64"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
