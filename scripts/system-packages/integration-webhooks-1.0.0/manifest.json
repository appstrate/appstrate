{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/webhooks",
  "version": "1.0.0",
  "displayName": "Webhooks (API)",
  "description": "Generic webhook provider \u2014 send HTTP requests to any URL with optional authentication",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "webhook",
  "keywords": ["integration", "automation"],
  "apiCall": {
    "authKey": "primary"
  },
  "auths": {
    "primary": {
      "type": "custom",
      "required": true,
      "authorizedUris": [],
      "allowAllUris": true,
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "webhook_url": {
              "type": "string",
              "description": "Target webhook URL"
            },
            "secret_header_name": {
              "type": "string",
              "description": "Custom authentication header name (e.g. X-Webhook-Secret) \u2014 optional"
            },
            "secret_header_value": {
              "type": "string",
              "description": "Secret value for the authentication header \u2014 optional"
            }
          },
          "required": ["webhook_url"]
        }
      },
      "delivery": {
        "http": {}
      }
    }
  }
}
