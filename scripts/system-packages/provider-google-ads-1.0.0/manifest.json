{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/google-ads",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Google Ads",
  "description": "Online advertising platform by Google — manage campaigns, ad groups, and keywords",
  "iconUrl": "googleads",
  "categories": ["advertising", "marketing"],
  "docsUrl": "https://developers.google.com/google-ads/api/docs/start",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "refreshUrl": "https://oauth2.googleapis.com/token",
      "defaultScopes": ["https://www.googleapis.com/auth/adwords"],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post",
      "authorizationParams": {
        "access_type": "offline",
        "prompt": "consent"
      }
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://googleads.googleapis.com/*"]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the authorized redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Apply for a Google Ads API developer token",
        "url": "https://developers.google.com/google-ads/api/docs/get-started/dev-token"
      },
      {
        "label": "Enable the Google Ads API",
        "url": "https://console.cloud.google.com/apis/library/googleads.googleapis.com"
      },
      {
        "label": "Create OAuth credentials",
        "url": "https://console.cloud.google.com/apis/credentials"
      }
    ]
  },
  "schemaVersion": "1.0"
}
