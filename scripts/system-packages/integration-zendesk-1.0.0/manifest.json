{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/zendesk",
  "version": "1.0.0",
  "displayName": "Zendesk (API)",
  "description": "Customer service and support ticketing platform",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "zendesk",
  "keywords": ["crm", "support", "customer-service"],
  "server": {
    "type": "api_call"
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "required": true,
      "authorizedUris": ["https://*.zendesk.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Zendesk API token (found in Admin Center > Apps and integrations > Zendesk API)"
            },
            "email": {
              "type": "string",
              "description": "Email address of the Zendesk agent (used for authentication)"
            },
            "subdomain": {
              "type": "string",
              "description": "Your Zendesk subdomain (e.g. 'mycompany' from mycompany.zendesk.com)"
            }
          },
          "required": ["api_key", "email", "subdomain"]
        }
      },
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Basic",
          "valueFrom": {
            "template": "{{email}}/token:{{api_key}}",
            "encoding": "base64"
          }
        }
      }
    }
  }
}
