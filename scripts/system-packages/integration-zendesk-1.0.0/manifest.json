{
  "name": "@appstrate/zendesk",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "2.0",
  "display_name": "Zendesk (API)",
  "description": "Customer service and support ticketing platform",
  "keywords": ["crm", "support", "customer-service"],
  "license": "Apache-2.0",
  "icon": "zendesk",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "authorized_uris": ["https://*.zendesk.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Zendesk API token (found in Admin Center > Apps and integrations > Zendesk API)"
            },
            "email": {
              "type": "string",
              "description": "Email address of the Zendesk agent (used for authentication)"
            },
            "subdomain": {
              "type": "string",
              "description": "Your Zendesk subdomain (e.g. 'mycompany' from mycompany.zendesk.com)"
            }
          },
          "required": ["api_key", "email", "subdomain"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Basic",
          "value": "{$credential.email}/token:{$credential.api_key}",
          "encoding": "base64"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
