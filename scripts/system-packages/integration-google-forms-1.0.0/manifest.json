{
  "name": "@appstrate/google-forms",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Google Forms (API)",
  "description": "Form creation and response collection by Google",
  "keywords": ["forms", "productivity"],
  "license": "Apache-2.0",
  "icon": "simple-icons:googleforms",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "issuer": "https://accounts.google.com",
      "default_scopes": [
        "openid",
        "email",
        "https://www.googleapis.com/auth/forms.body.readonly",
        "https://www.googleapis.com/auth/forms.responses.readonly"
      ],
      "authorization_params": {
        "access_type": "offline",
        "prompt": "consent"
      },
      "token_endpoint_auth_method": "client_secret_post",
      "identity_claims": {
        "accountId": "$.email",
        "sub": "$.sub",
        "email": "$.email",
        "name": "$.name",
        "picture": "$.picture"
      },
      "scope_catalog": [
        {
          "value": "openid",
          "label": "Identity (OpenID)"
        },
        {
          "value": "email",
          "label": "Email address"
        },
        {
          "value": "https://www.googleapis.com/auth/forms.body.readonly",
          "label": "Read form structure"
        },
        {
          "value": "https://www.googleapis.com/auth/forms.body",
          "label": "Read and edit form structure"
        },
        {
          "value": "https://www.googleapis.com/auth/forms.responses.readonly",
          "label": "Read form responses"
        },
        {
          "value": "https://www.googleapis.com/auth/drive.readonly",
          "label": "Read Google Drive (list forms)"
        },
        {
          "value": "https://www.googleapis.com/auth/drive",
          "label": "Full Google Drive access"
        }
      ],
      "authorized_uris": ["https://forms.googleapis.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
