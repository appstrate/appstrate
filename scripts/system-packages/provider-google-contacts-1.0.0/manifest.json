{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/google-contacts",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Google Contacts",
  "description": "Contact management service by Google",
  "iconUrl": "googlecontacts",
  "categories": ["contacts", "productivity"],
  "docsUrl": "https://developers.google.com/people/api/rest",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "refreshUrl": "https://oauth2.googleapis.com/token",
      "defaultScopes": [
        "https://www.googleapis.com/auth/contacts.readonly"
      ],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post",
      "authorizationParams": {
        "access_type": "offline",
        "prompt": "consent"
      }
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://people.googleapis.com/*"],
    "availableScopes": [
      { "value": "https://www.googleapis.com/auth/contacts.readonly", "label": "Read contacts" },
      { "value": "https://www.googleapis.com/auth/contacts", "label": "Read and write contacts" },
      { "value": "https://www.googleapis.com/auth/contacts.other.readonly", "label": "Read 'Other contacts' (auto-suggested)" },
      { "value": "https://www.googleapis.com/auth/directory.readonly", "label": "Read organization directory (Google Workspace)" },
      { "value": "https://www.googleapis.com/auth/userinfo.profile", "label": "Read user profile info" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the authorized redirect URI to: {{callbackUrl}}",
    "steps": [
      { "label": "Enable the People API", "url": "https://console.cloud.google.com/apis/library/people.googleapis.com" },
      { "label": "Configure the OAuth consent screen", "url": "https://console.cloud.google.com/apis/credentials/consent" },
      { "label": "Create OAuth credentials", "url": "https://console.cloud.google.com/apis/credentials" }
    ]
  },
  "schemaVersion": "1.0"
}
