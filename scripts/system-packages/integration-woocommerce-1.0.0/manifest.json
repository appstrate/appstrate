{
  "name": "@appstrate/woocommerce",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "WooCommerce (API)",
  "description": "E-commerce plugin for WordPress — manage products, orders, customers, and coupons",
  "keywords": ["e-commerce", "retail"],
  "license": "Apache-2.0",
  "icon": "woo",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "custom",
      "authorized_uris": [],
      "allow_all_uris": true,
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "site_url": {
              "type": "string",
              "description": "WooCommerce site URL (e.g. https://mystore.com)"
            },
            "consumer_key": {
              "type": "string",
              "description": "Consumer Key (starts with ck_)"
            },
            "consumer_secret": {
              "type": "string",
              "description": "Consumer Secret (starts with cs_)"
            }
          },
          "required": ["site_url", "consumer_key", "consumer_secret"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Basic",
          "value": "{$credential.consumer_key}:{$credential.consumer_secret}",
          "encoding": "base64"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
