{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/typeform",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Typeform",
  "description": "Online form builder and survey platform",
  "iconUrl": "typeform",
  "categories": ["forms", "surveys"],
  "docsUrl": "https://www.typeform.com/developers/",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://api.typeform.com/oauth/authorize",
      "tokenUrl": "https://api.typeform.com/oauth/token",
      "refreshUrl": "https://api.typeform.com/oauth/token",
      "defaultScopes": ["accounts:read", "forms:read", "responses:read", "offline"],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.typeform.com/**"],
    "availableScopes": [
      { "value": "accounts:read", "label": "Read account info" },
      { "value": "forms:read", "label": "Read forms" },
      { "value": "forms:write", "label": "Create and edit forms" },
      { "value": "responses:read", "label": "Read form responses" },
      { "value": "responses:write", "label": "Delete responses" },
      { "value": "workspaces:read", "label": "Read workspaces" },
      { "value": "workspaces:write", "label": "Create and edit workspaces" },
      { "value": "webhooks:read", "label": "Read webhooks" },
      { "value": "webhooks:write", "label": "Create and edit webhooks" },
      { "value": "offline", "label": "Enable refresh tokens" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Create a Typeform OAuth application",
        "url": "https://admin.typeform.com/account#/section/tokens"
      },
      { "label": "Configure the redirect URI and scopes" },
      { "label": "Copy your Client ID and Client Secret" }
    ]
  },
  "schemaVersion": "1.1"
}
