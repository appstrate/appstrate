{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/x",
  "version": "1.0.0",
  "displayName": "X (Twitter) (API)",
  "description": "Social media platform for microblogging and real-time engagement",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "x",
  "keywords": ["social-media", "marketing"],
  "apiCall": {
    "authKey": "primary"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": ["https://api.x.com/**"],
      "authorizationUrl": "https://x.com/i/oauth2/authorize",
      "tokenUrl": "https://api.x.com/2/oauth2/token",
      "refreshUrl": "https://api.x.com/2/oauth2/token",
      "scopes": ["tweet.read", "users.read", "offline.access"],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_basic",
      "availableScopes": [
        {
          "value": "tweet.read",
          "label": "Read tweets"
        },
        {
          "value": "tweet.write",
          "label": "Post & delete tweets"
        },
        {
          "value": "tweet.moderate.write",
          "label": "Moderate tweet replies"
        },
        {
          "value": "users.read",
          "label": "Read user profiles"
        },
        {
          "value": "follows.read",
          "label": "Read followers & following"
        },
        {
          "value": "follows.write",
          "label": "Follow & unfollow users"
        },
        {
          "value": "like.read",
          "label": "Read likes"
        },
        {
          "value": "like.write",
          "label": "Like & unlike tweets"
        },
        {
          "value": "list.read",
          "label": "Read lists"
        },
        {
          "value": "list.write",
          "label": "Create & manage lists"
        },
        {
          "value": "bookmark.read",
          "label": "Read bookmarks"
        },
        {
          "value": "bookmark.write",
          "label": "Manage bookmarks"
        },
        {
          "value": "space.read",
          "label": "Read Spaces"
        },
        {
          "value": "dm.read",
          "label": "Read direct messages"
        },
        {
          "value": "dm.write",
          "label": "Send direct messages"
        },
        {
          "value": "offline.access",
          "label": "Refresh token (long-lived access)"
        }
      ],
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "access_token"
        }
      }
    }
  }
}
