{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/connect-bearer-test",
  "version": "1.0.0",
  "displayName": "Connect Bearer Test",
  "description": "Phase 3 reference — exercises the declarative login (single Bearer-token request) (`connect.steps`). A petitspas-shaped OAuth2 password grant against https://bearer.test.appstrate.dev: POST the credentials, extract `access_token` + `expires_in` from JSON, and pull `person_id` from the JWT's `AUTH[0].personId` claim. No untrusted code runs — the platform-side engine drives the chain and substitutes `{{email}}`/`{{password}}` at the boundary. Used by the connect E2E to confirm a manifest connects end-to-end against a fake upstream.",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "keywords": ["connect", "bearer", "test"],
  "server": {
    "type": "api_call"
  },
  "auths": {
    "session": {
      "type": "custom",
      "required": true,
      "authorizedUris": ["https://bearer.test.appstrate.dev/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "required": ["email", "password"],
          "properties": {
            "email": { "type": "string", "description": "Account email (login)" },
            "password": {
              "type": "string",
              "description": "Account password — never seen by any tool; the platform engine substitutes it into the token request at the boundary."
            }
          }
        }
      },
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer ",
          "valueFrom": "access_token"
        }
      },
      "connect": {
        "steps": [
          {
            "request": {
              "method": "POST",
              "url": "https://bearer.test.appstrate.dev/oauth/token",
              "contentType": "application/x-www-form-urlencoded",
              "body": "grant_type=password&username={{email}}&password={{password}}"
            },
            "extract": {
              "access_token": { "from": "json", "path": "$.access_token" },
              "expires_in": { "from": "json", "path": "$.expires_in" },
              "person_id": { "from": "jwt", "token": "access_token", "path": "$.AUTH[0].personId" }
            },
            "output": ["access_token", "expires_in", "person_id"]
          }
        ],
        "expiresInOutput": "expires_in",
        "identityOutputs": ["person_id"]
      }
    }
  }
}
