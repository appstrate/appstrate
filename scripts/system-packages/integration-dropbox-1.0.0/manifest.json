{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/dropbox",
  "version": "1.0.0",
  "displayName": "Dropbox (API)",
  "description": "Cloud file storage, sync, and sharing platform",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "dropbox",
  "keywords": ["storage", "productivity"],
  "apiCall": {
    "authKey": "primary"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": ["https://api.dropboxapi.com/**", "https://content.dropboxapi.com/**"],
      "authorizationUrl": "https://www.dropbox.com/oauth2/authorize",
      "tokenUrl": "https://api.dropboxapi.com/oauth2/token",
      "refreshUrl": "https://api.dropboxapi.com/oauth2/token",
      "scopes": ["account_info.read", "files.metadata.read", "files.content.read"],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post",
      "availableScopes": [
        {
          "value": "account_info.read",
          "label": "Read account info"
        },
        {
          "value": "files.metadata.read",
          "label": "Read file and folder metadata"
        },
        {
          "value": "files.metadata.write",
          "label": "Write file and folder metadata"
        },
        {
          "value": "files.content.read",
          "label": "Read file content"
        },
        {
          "value": "files.content.write",
          "label": "Write file content"
        },
        {
          "value": "sharing.read",
          "label": "Read shared files and folders"
        },
        {
          "value": "sharing.write",
          "label": "Manage shared files and folders"
        },
        {
          "value": "file_requests.read",
          "label": "Read file requests"
        },
        {
          "value": "file_requests.write",
          "label": "Manage file requests"
        }
      ],
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "accessToken"
        }
      }
    }
  }
}
