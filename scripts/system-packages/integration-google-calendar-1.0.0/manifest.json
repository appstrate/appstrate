{
  "name": "@appstrate/google-calendar",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Google Calendar (API)",
  "description": "Calendar and scheduling service by Google",
  "keywords": ["calendar", "productivity"],
  "license": "Apache-2.0",
  "icon": "logos:google-calendar",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "issuer": "https://accounts.google.com",
      "default_scopes": ["openid", "email", "https://www.googleapis.com/auth/calendar.readonly"],
      "authorization_params": {
        "access_type": "offline",
        "prompt": "consent"
      },
      "token_endpoint_auth_method": "client_secret_post",
      "identity_claims": {
        "accountId": "$.email",
        "sub": "$.sub",
        "email": "$.email",
        "name": "$.name",
        "picture": "$.picture"
      },
      "scope_catalog": [
        {
          "value": "openid",
          "label": "Identity (OpenID)"
        },
        {
          "value": "email",
          "label": "Email address"
        },
        {
          "value": "https://www.googleapis.com/auth/calendar.readonly",
          "label": "Read-only access to calendars and events"
        },
        {
          "value": "https://www.googleapis.com/auth/calendar",
          "label": "Full calendar access (read & write)"
        },
        {
          "value": "https://www.googleapis.com/auth/calendar.events",
          "label": "Manage events on all calendars"
        },
        {
          "value": "https://www.googleapis.com/auth/calendar.events.readonly",
          "label": "Read events only"
        },
        {
          "value": "https://www.googleapis.com/auth/calendar.settings.readonly",
          "label": "Read calendar settings"
        },
        {
          "value": "https://www.googleapis.com/auth/calendar.freebusy",
          "label": "Read free/busy information"
        }
      ],
      "authorized_uris": ["https://www.googleapis.com/calendar/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
