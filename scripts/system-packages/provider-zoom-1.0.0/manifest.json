{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/zoom",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Zoom",
  "description": "Video conferencing and online meetings platform",
  "iconUrl": "zoom",
  "categories": ["video", "meetings"],
  "docsUrl": "https://developers.zoom.us/docs/api/",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://zoom.us/oauth/authorize",
      "tokenUrl": "https://zoom.us/oauth/token",
      "refreshUrl": "https://zoom.us/oauth/token",
      "defaultScopes": ["user:read:user", "meeting:read:list_meetings", "meeting:read:meeting"],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_basic"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.zoom.us/**"],
    "availableScopes": [
      { "value": "user:read:user", "label": "Read user profile" },
      { "value": "meeting:read:list_meetings", "label": "List meetings" },
      { "value": "meeting:read:meeting", "label": "Read meeting details" },
      { "value": "meeting:write:meeting", "label": "Create and update meetings" },
      { "value": "meeting:delete:meeting", "label": "Delete meetings" },
      { "value": "recording:read:list_recording_files", "label": "List cloud recordings" },
      { "value": "recording:read:recording", "label": "Read recording details" },
      { "value": "webinar:read:list_webinars", "label": "List webinars" },
      { "value": "webinar:read:webinar", "label": "Read webinar details" },
      {
        "value": "report:read:list_meeting_participants",
        "label": "Read meeting participants report"
      }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      { "label": "Create a Zoom OAuth app", "url": "https://marketplace.zoom.us/develop/create" },
      { "label": "Configure OAuth scopes and redirect URI" },
      { "label": "Copy your Client ID and Client Secret" }
    ]
  },
  "schemaVersion": "1.0"
}
