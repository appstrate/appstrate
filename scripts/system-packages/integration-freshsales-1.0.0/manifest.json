{
  "name": "@appstrate/freshsales",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Freshsales (API)",
  "description": "CRM platform for sales teams with AI-powered lead scoring",
  "keywords": ["crm", "sales"],
  "license": "Apache-2.0",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "authorized_uris": ["https://*.myfreshworks.com/**", "https://*.freshsales.io/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Freshsales API key (found in Settings > API Settings)"
            },
            "subdomain": {
              "type": "string",
              "description": "Your Freshworks subdomain (e.g. 'mycompany' from mycompany.myfreshworks.com)"
            }
          },
          "required": ["api_key", "subdomain"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Token token=",
          "value": "{$credential.api_key}"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
