{
  "name": "@appstrate/quickbooks-online",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "QuickBooks Online (API)",
  "description": "Cloud accounting software by Intuit — invoicing, expenses, and financial reporting",
  "keywords": ["accounting", "finance"],
  "license": "Apache-2.0",
  "icon": "quickbooks",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://appcenter.intuit.com/connect/oauth2",
      "token_endpoint": "https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer",
      "default_scopes": ["com.intuit.quickbooks.accounting"],
      "token_endpoint_auth_method": "client_secret_basic",
      "scope_catalog": [
        {
          "value": "com.intuit.quickbooks.accounting",
          "label": "Accounting data (invoices, customers, payments)"
        },
        {
          "value": "com.intuit.quickbooks.payment",
          "label": "Payment processing"
        },
        {
          "value": "openid",
          "label": "OpenID Connect"
        },
        {
          "value": "profile",
          "label": "User profile"
        },
        {
          "value": "email",
          "label": "User email"
        }
      ],
      "authorized_uris": [
        "https://quickbooks.api.intuit.com/**",
        "https://sandbox-quickbooks.api.intuit.com/**"
      ],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
