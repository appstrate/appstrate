{
  "name": "@appstrate/github-mcp",
  "version": "1.1.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "GitHub",
  "icon": "logos:github-icon",
  "description": "GitHub integration backed by GitHub's official remote MCP server (api.githubcopilot.com/mcp/). Full ~80-tool catalog spanning every documented toolset (context, repos, issues, pull_requests, actions, code_security, secret_protection, dependabot, notifications, users, orgs, projects, gists, discussions, copilot, copilot_spaces, git, labels, stargazers, security_advisories, github_support_docs_search). Two interchangeable auth paths: (1) OAuth — full OAuth App flow with per-tool scope inference; (2) PAT — Personal Access Token Bearer. GitHub MCP does not support Dynamic Client Registration: OAuth requires an OAuth App registered in the user's GitHub account. The selected access token is Bearer-injected on every MCP request by the sidecar.",
  "license": "Apache-2.0",
  "source": {
    "kind": "remote",
    "remote": {
      "url": "https://api.githubcopilot.com/mcp/x/all",
      "transport": "streamable-http"
    }
  },
  "allow_undeclared_tools": true,
  "auths": {
    "oauth": {
      "type": "oauth2",
      "authorization_endpoint": "https://github.com/login/oauth/authorize",
      "token_endpoint": "https://github.com/login/oauth/access_token",
      "userinfo_endpoint": "https://api.github.com/user",
      "default_scopes": [
        "read:user",
        "repo",
        "read:org",
        "workflow",
        "security_events",
        "notifications",
        "gist",
        "read:discussion",
        "write:discussion",
        "read:project",
        "project"
      ],
      "token_endpoint_auth_method": "client_secret_post",
      "identity_claims": {
        "accountId": "$.login",
        "sub": "$.id",
        "login": "$.login",
        "name": "$.name",
        "email": "$.email",
        "avatarUrl": "$.avatar_url"
      },
      "scope_catalog": [
        {
          "value": "read:user",
          "label": "Read profile",
          "description": "Read access to the authenticated user's profile (get_me, copilot_spaces)."
        },
        {
          "value": "user:email",
          "label": "User email",
          "description": "Access the authenticated user's email addresses."
        },
        {
          "value": "public_repo",
          "label": "Public repos",
          "description": "Read + write public repositories (commits, issues, PRs, stars, forks)."
        },
        {
          "value": "repo",
          "label": "All repos",
          "description": "Full access to private + public repositories (writes, branches, files, collaborators).",
          "implies": ["public_repo", "repo:status", "repo_deployment", "security_events"]
        },
        {
          "value": "repo:status",
          "label": "Commit status",
          "description": "Read/write commit statuses (CI/CD signals)."
        },
        {
          "value": "repo_deployment",
          "label": "Deployments",
          "description": "Access deployment statuses."
        },
        {
          "value": "read:org",
          "label": "Read orgs",
          "description": "Read org membership, teams, and projects."
        },
        {
          "value": "write:org",
          "label": "Write orgs",
          "description": "Publicize/unpublicize membership and manage teams.",
          "implies": ["read:org"]
        },
        {
          "value": "admin:org",
          "label": "Admin orgs",
          "description": "Full admin access to organizations (rarely needed).",
          "implies": ["write:org", "read:org"]
        },
        {
          "value": "gist",
          "label": "Gists",
          "description": "Create and manage gists."
        },
        {
          "value": "notifications",
          "label": "Notifications",
          "description": "List, mark, dismiss, and manage notification subscriptions."
        },
        {
          "value": "workflow",
          "label": "Workflows",
          "description": "Trigger, cancel, rerun GitHub Actions workflow runs and inspect job logs."
        },
        {
          "value": "security_events",
          "label": "Security alerts",
          "description": "Read code scanning, secret scanning, and Dependabot alerts."
        },
        {
          "value": "read:project",
          "label": "Read projects",
          "description": "Read GitHub Projects (boards, items, fields)."
        },
        {
          "value": "project",
          "label": "Write projects",
          "description": "Modify GitHub Projects items, fields, and statuses.",
          "implies": ["read:project"]
        },
        {
          "value": "read:discussion",
          "label": "Read discussions",
          "description": "Read GitHub Discussions (threads, comments, categories)."
        },
        {
          "value": "write:discussion",
          "label": "Write discussions",
          "description": "Create and update discussion comments.",
          "implies": ["read:discussion"]
        },
        {
          "value": "delete_repo",
          "label": "Delete repos",
          "description": "Delete repositories (irreversible — grant with care)."
        },
        {
          "value": "read:packages",
          "label": "Read packages",
          "description": "Read packages published to GitHub Packages."
        },
        {
          "value": "write:packages",
          "label": "Write packages",
          "description": "Publish and update packages on GitHub Packages.",
          "implies": ["read:packages"]
        }
      ],
      "authorized_uris": ["https://api.githubcopilot.com/**", "https://api.github.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer ",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": false
        }
      }
    },
    "pat": {
      "type": "api_key",
      "authorized_uris": ["https://api.githubcopilot.com/**", "https://api.github.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "required": ["personal_access_token"],
          "properties": {
            "personal_access_token": {
              "type": "string",
              "description": "GitHub Personal Access Token (classic at https://github.com/settings/tokens, or fine-grained at https://github.com/settings/personal-access-tokens). For full functionality grant the equivalent of `repo + workflow + notifications + gist + read:org + security_events + project + write:discussion + write:packages`. Injected as `Authorization: Bearer <PAT>`."
            }
          }
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer ",
          "value": "{$credential.personal_access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": false
        }
      }
    }
  },
