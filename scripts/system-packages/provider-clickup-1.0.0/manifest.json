{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/clickup",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "ClickUp",
  "description": "Project management and productivity platform",
  "iconUrl": "clickup",
  "categories": ["productivity", "project-management"],
  "docsUrl": "https://developer.clickup.com/docs/Getting%20Started",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://app.clickup.com/api",
      "tokenUrl": "https://api.clickup.com/api/v2/oauth/token",
      "defaultScopes": [],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.clickup.com/**"]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URL to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Create a ClickUp app",
        "url": "https://app.clickup.com/settings"
      },
      {
        "label": "Copy your credentials"
      }
    ]
  },
  "schemaVersion": "1.1"
}
