{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/github-mcp",
  "version": "1.0.0",
  "displayName": "GitHub",
  "description": "GitHub integration backed by GitHub's official remote MCP server (api.githubcopilot.com/mcp/). Full ~80-tool catalog spanning every documented toolset (context, repos, issues, pull_requests, actions, code_security, secret_protection, dependabot, notifications, users, orgs, projects, gists, discussions, copilot, copilot_spaces, git, labels, stargazers, security_advisories, github_support_docs_search). Two interchangeable auth paths: (1) OAuth — full OAuth App flow with per-tool scope inference; (2) PAT — Personal Access Token Bearer. GitHub MCP does not support Dynamic Client Registration: OAuth requires an OAuth App registered in the user's GitHub account. The selected access token is Bearer-injected on every MCP request by the sidecar.",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "iconUrl": "github",
  "categories": ["development", "code", "issue-tracking", "ci-cd"],
  "server": {
    "type": "http",
    "url": "https://api.githubcopilot.com/mcp/"
  },
  "transport": {
    "type": "streamable-http"
  },
  "auths": {
    "oauth": {
      "type": "oauth2",
      "required": false,
      "authorizationUrl": "https://github.com/login/oauth/authorize",
      "tokenUrl": "https://github.com/login/oauth/access_token",
      "refreshUrl": "https://github.com/login/oauth/access_token",
      "userinfoUrl": "https://api.github.com/user",
      "extractTokenIdentity": {
        "accountId": "$.login",
        "sub": "$.id",
        "login": "$.login",
        "name": "$.name",
        "email": "$.email",
        "avatarUrl": "$.avatar_url"
      },
      "scopes": ["read:user", "repo"],
      "scopeSeparator": " ",
      "tokenAuthMethod": "client_secret_post",
      "authorizedUris": ["https://api.githubcopilot.com/**", "https://api.github.com/**"],
      "availableScopes": [
        {
          "value": "read:user",
          "label": "Read profile",
          "description": "Read access to the authenticated user's profile (get_me, copilot_spaces)."
        },
        {
          "value": "user:email",
          "label": "User email",
          "description": "Access the authenticated user's email addresses."
        },
        {
          "value": "public_repo",
          "label": "Public repos",
          "description": "Read + write public repositories (commits, issues, PRs, stars, forks)."
        },
        {
          "value": "repo",
          "label": "All repos",
          "description": "Full access to private + public repositories (writes, branches, files, collaborators).",
          "implies": ["public_repo", "repo:status", "repo_deployment", "security_events"]
        },
        {
          "value": "repo:status",
          "label": "Commit status",
          "description": "Read/write commit statuses (CI/CD signals)."
        },
        {
          "value": "repo_deployment",
          "label": "Deployments",
          "description": "Access deployment statuses."
        },
        {
          "value": "read:org",
          "label": "Read orgs",
          "description": "Read org membership, teams, and projects."
        },
        {
          "value": "write:org",
          "label": "Write orgs",
          "description": "Publicize/unpublicize membership and manage teams.",
          "implies": ["read:org"]
        },
        {
          "value": "admin:org",
          "label": "Admin orgs",
          "description": "Full admin access to organizations (rarely needed).",
          "implies": ["write:org", "read:org"]
        },
        { "value": "gist", "label": "Gists", "description": "Create and manage gists." },
        {
          "value": "notifications",
          "label": "Notifications",
          "description": "List, mark, dismiss, and manage notification subscriptions."
        },
        {
          "value": "workflow",
          "label": "Workflows",
          "description": "Trigger, cancel, rerun GitHub Actions workflow runs and inspect job logs."
        },
        {
          "value": "security_events",
          "label": "Security alerts",
          "description": "Read code scanning, secret scanning, and Dependabot alerts."
        },
        {
          "value": "read:project",
          "label": "Read projects",
          "description": "Read GitHub Projects (boards, items, fields)."
        },
        {
          "value": "project",
          "label": "Write projects",
          "description": "Modify GitHub Projects items, fields, and statuses.",
          "implies": ["read:project"]
        },
        {
          "value": "read:discussion",
          "label": "Read discussions",
          "description": "Read GitHub Discussions (threads, comments, categories)."
        },
        {
          "value": "write:discussion",
          "label": "Write discussions",
          "description": "Create and update discussion comments.",
          "implies": ["read:discussion"]
        },
        {
          "value": "delete_repo",
          "label": "Delete repos",
          "description": "Delete repositories (irreversible — grant with care)."
        },
        {
          "value": "read:packages",
          "label": "Read packages",
          "description": "Read packages published to GitHub Packages."
        },
        {
          "value": "write:packages",
          "label": "Write packages",
          "description": "Publish and update packages on GitHub Packages.",
          "implies": ["read:packages"]
        }
      ],
      "delivery": { "http": {} }
    },
    "pat": {
      "type": "api_key",
      "required": false,
      "authorizedUris": ["https://api.githubcopilot.com/**", "https://api.github.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "required": ["personal_access_token"],
          "properties": {
            "personal_access_token": {
              "type": "string",
              "description": "GitHub Personal Access Token (classic at https://github.com/settings/tokens, or fine-grained at https://github.com/settings/personal-access-tokens). For full functionality grant the equivalent of `repo + workflow + notifications + gist + read:org + security_events + project + write:discussion + write:packages`. Injected as `Authorization: Bearer <PAT>`."
            }
          }
        }
      },
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer ",
          "valueFrom": "personal_access_token"
        }
      }
    }
  },
  "tools": {
    "get_me": { "requiredAuthKey": "oauth", "requiredScopes": ["read:user"] },
    "get_teams": { "requiredAuthKey": "oauth", "requiredScopes": ["read:org"] },
    "get_team_members": { "requiredAuthKey": "oauth", "requiredScopes": ["read:org"] },

    "search_repositories": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "search_code": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_branches": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_commits": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "get_commit": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_tags": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "get_tag": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "get_file_contents": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_releases": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "get_latest_release": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "get_release_by_tag": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_repository_collaborators": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "create_branch": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "create_or_update_file": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "create_repository": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "delete_file": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "fork_repository": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "push_files": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },

    "search_issues": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_issues": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "issue_read": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_issue_types": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "issue_write": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "add_issue_comment": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "sub_issue_write": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },

    "search_pull_requests": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "list_pull_requests": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "pull_request_read": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "create_pull_request": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "update_pull_request": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "update_pull_request_branch": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "merge_pull_request": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "pull_request_review_write": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "add_comment_to_pending_review": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "add_reply_to_pull_request_comment": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },

    "actions_list": { "requiredAuthKey": "oauth", "requiredScopes": ["workflow"] },
    "actions_get": { "requiredAuthKey": "oauth", "requiredScopes": ["workflow"] },
    "get_job_logs": { "requiredAuthKey": "oauth", "requiredScopes": ["workflow"] },
    "actions_run_trigger": { "requiredAuthKey": "oauth", "requiredScopes": ["workflow"] },

    "list_code_scanning_alerts": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["security_events"]
    },
    "get_code_scanning_alert": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["security_events"]
    },

    "list_secret_scanning_alerts": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["security_events"]
    },
    "get_secret_scanning_alert": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["security_events"]
    },

    "list_dependabot_alerts": { "requiredAuthKey": "oauth", "requiredScopes": ["security_events"] },
    "get_dependabot_alert": { "requiredAuthKey": "oauth", "requiredScopes": ["security_events"] },

    "list_notifications": { "requiredAuthKey": "oauth", "requiredScopes": ["notifications"] },
    "get_notification_details": { "requiredAuthKey": "oauth", "requiredScopes": ["notifications"] },
    "mark_all_notifications_read": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["notifications"]
    },
    "dismiss_notification": { "requiredAuthKey": "oauth", "requiredScopes": ["notifications"] },
    "manage_notification_subscription": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["notifications"]
    },
    "manage_repository_notification_subscription": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["notifications"]
    },

    "search_users": { "requiredAuthKey": "oauth", "requiredScopes": [] },

    "search_orgs": { "requiredAuthKey": "oauth", "requiredScopes": [] },

    "projects_list": { "requiredAuthKey": "oauth", "requiredScopes": ["read:project"] },
    "projects_get": { "requiredAuthKey": "oauth", "requiredScopes": ["read:project"] },
    "projects_write": { "requiredAuthKey": "oauth", "requiredScopes": ["project"] },

    "list_gists": { "requiredAuthKey": "oauth", "requiredScopes": ["gist"] },
    "get_gist": { "requiredAuthKey": "oauth", "requiredScopes": ["gist"] },
    "create_gist": { "requiredAuthKey": "oauth", "requiredScopes": ["gist"] },
    "update_gist": { "requiredAuthKey": "oauth", "requiredScopes": ["gist"] },

    "list_discussions": { "requiredAuthKey": "oauth", "requiredScopes": ["read:discussion"] },
    "list_discussion_categories": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["read:discussion"]
    },
    "get_discussion": { "requiredAuthKey": "oauth", "requiredScopes": ["read:discussion"] },
    "get_discussion_comments": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["read:discussion"]
    },
    "discussion_comment_write": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["write:discussion"]
    },

    "assign_copilot_to_issue": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "request_copilot_review": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },
    "create_pull_request_with_copilot": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },

    "list_copilot_spaces": { "requiredAuthKey": "oauth", "requiredScopes": ["read:user"] },
    "get_copilot_space": { "requiredAuthKey": "oauth", "requiredScopes": ["read:user"] },

    "get_repository_tree": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },

    "list_label": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "get_label": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "label_write": { "requiredAuthKey": "oauth", "requiredScopes": ["repo"] },

    "list_starred_repositories": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "star_repository": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },
    "unstar_repository": { "requiredAuthKey": "oauth", "requiredScopes": ["public_repo"] },

    "list_global_security_advisories": { "requiredAuthKey": "oauth", "requiredScopes": [] },
    "get_global_security_advisory": { "requiredAuthKey": "oauth", "requiredScopes": [] },
    "list_repository_security_advisories": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["repo"]
    },
    "list_org_repository_security_advisories": {
      "requiredAuthKey": "oauth",
      "requiredScopes": ["repo"]
    },

    "github_support_docs_search": { "requiredAuthKey": "oauth", "requiredScopes": [] }
  }
}
