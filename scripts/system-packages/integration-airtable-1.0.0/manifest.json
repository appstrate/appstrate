{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/airtable",
  "version": "1.0.0",
  "displayName": "Airtable (API)",
  "description": "Low-code platform for building collaborative databases and apps",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "airtable",
  "keywords": ["project-management", "database", "collaboration"],
  "server": {
    "type": "api_call"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": ["https://api.airtable.com/**"],
      "authorizationUrl": "https://airtable.com/oauth2/v1/authorize",
      "tokenUrl": "https://airtable.com/oauth2/v1/token",
      "refreshUrl": "https://airtable.com/oauth2/v1/token",
      "scopes": ["data.records:read", "schema.bases:read"],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post",
      "availableScopes": [
        {
          "value": "data.records:read",
          "label": "Read records"
        },
        {
          "value": "data.records:write",
          "label": "Create, update, and delete records"
        },
        {
          "value": "data.recordComments:read",
          "label": "Read record comments"
        },
        {
          "value": "data.recordComments:write",
          "label": "Create and manage comments"
        },
        {
          "value": "schema.bases:read",
          "label": "Read base schema (tables, fields)"
        },
        {
          "value": "schema.bases:write",
          "label": "Modify base schema"
        },
        {
          "value": "webhook:manage",
          "label": "Manage webhooks"
        },
        {
          "value": "block:manage",
          "label": "Manage extensions/blocks"
        },
        {
          "value": "user.email:read",
          "label": "Read user email"
        }
      ],
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "accessToken"
        }
      }
    }
  }
}
