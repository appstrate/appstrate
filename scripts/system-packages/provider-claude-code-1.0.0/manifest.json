{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/provider.schema.json",
  "name": "@appstrate/provider-claude-code",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Claude Code (Anthropic)",
  "description": "Run agents against your Claude Pro / Max / Team subscription via the Claude Code OAuth client.",
  "iconUrl": "anthropic",
  "categories": ["llm", "model-provider"],
  "docsUrl": "https://docs.anthropic.com/en/docs/claude-code/overview",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://claude.ai/oauth/authorize",
      "tokenUrl": "https://platform.claude.com/v1/oauth/token",
      "refreshUrl": "https://platform.claude.com/v1/oauth/token",
      "defaultScopes": ["org:create_api_key", "user:profile", "user:inference"],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.anthropic.com/**"],
    "availableScopes": [
      { "value": "user:inference", "label": "Send messages on the connected account's behalf" },
      { "value": "user:profile", "label": "Read account profile" },
      { "value": "org:create_api_key", "label": "Create API keys (required for token refresh)" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "The redirect URI is provisioned by Appstrate (no manual setup). Click 'Connect via OAuth' in Settings > Models to start.",
    "steps": [
      {
        "label": "Active a Claude Pro, Max, or Team subscription",
        "url": "https://www.anthropic.com/pricing"
      },
      {
        "label": "Click 'Connect via OAuth' in Settings > Models inside Appstrate"
      }
    ]
  },
  "schemaVersion": "1.1"
}
