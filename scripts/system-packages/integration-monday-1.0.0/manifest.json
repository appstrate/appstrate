{
  "name": "@appstrate/monday",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Monday.com (API)",
  "description": "Work operating system for project management and team collaboration",
  "keywords": ["project-management", "collaboration"],
  "license": "Apache-2.0",
  "icon": "https://api.iconify.design/logos/monday-icon.svg",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://auth.monday.com/oauth2/authorize",
      "token_endpoint": "https://auth.monday.com/oauth2/token",
      "token_endpoint_auth_method": "client_secret_post",
      "scope_catalog": [
        {
          "value": "me:read",
          "label": "Read authenticated user info"
        },
        {
          "value": "boards:read",
          "label": "Read boards"
        },
        {
          "value": "boards:write",
          "label": "Create and modify boards"
        },
        {
          "value": "workspaces:read",
          "label": "Read workspaces"
        },
        {
          "value": "workspaces:write",
          "label": "Create and modify workspaces"
        },
        {
          "value": "users:read",
          "label": "Read users"
        },
        {
          "value": "users:write",
          "label": "Manage users"
        },
        {
          "value": "account:read",
          "label": "Read account info"
        },
        {
          "value": "updates:read",
          "label": "Read updates"
        },
        {
          "value": "updates:write",
          "label": "Create updates"
        }
      ],
      "authorized_uris": ["https://api.monday.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
