{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/shopify",
  "version": "1.0.0",
  "displayName": "Shopify (API)",
  "description": "E-commerce platform — manage products, orders, customers, and inventory",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "shopify",
  "keywords": ["e-commerce", "retail"],
  "server": {
    "type": "api_call"
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "required": true,
      "authorizedUris": ["https://*.myshopify.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "shop_domain": {
              "type": "string",
              "description": "Your Shopify store domain (e.g. mystore.myshopify.com)"
            },
            "access_token": {
              "type": "string",
              "description": "Admin API access token from a Custom App"
            }
          },
          "required": ["shop_domain", "access_token"]
        }
      },
      "delivery": {
        "http": {
          "headerName": "X-Shopify-Access-Token",
          "valueFrom": "access_token"
        }
      }
    }
  }
}
