{
  "name": "@appstrate/github",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "2.0",
  "display_name": "GitHub (API)",
  "description": "Code hosting and collaboration platform",
  "keywords": ["development", "code"],
  "license": "Apache-2.0",
  "icon": "github",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://github.com/login/oauth/authorize",
      "token_endpoint": "https://github.com/login/oauth/access_token",
      "default_scopes": ["repo", "read:user"],
      "token_endpoint_auth_method": "client_secret_post",
      "scope_catalog": [
        {
          "value": "repo",
          "label": "Full repository access"
        },
        {
          "value": "read:user",
          "label": "Read user profile"
        },
        {
          "value": "user:email",
          "label": "Read user emails"
        },
        {
          "value": "read:org",
          "label": "Read org membership"
        },
        {
          "value": "gist",
          "label": "Create gists"
        },
        {
          "value": "notifications",
          "label": "Access notifications"
        },
        {
          "value": "workflow",
          "label": "Update GitHub Actions workflows"
        }
      ],
      "authorized_uris": ["https://api.github.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
