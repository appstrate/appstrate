{
  "name": "@appstrate/linkedin",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "LinkedIn (API)",
  "description": "Professional networking and B2B marketing platform",
  "keywords": ["social-media", "marketing", "crm"],
  "license": "Apache-2.0",
  "icon": "logos:linkedin-icon",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://www.linkedin.com/oauth/v2/authorization",
      "token_endpoint": "https://www.linkedin.com/oauth/v2/accessToken",
      "default_scopes": ["openid", "profile", "email"],
      "token_endpoint_auth_method": "client_secret_post",
      "code_challenge_methods_supported": ["S256"],
      "scope_catalog": [
        {
          "value": "openid",
          "label": "OpenID Connect (required)"
        },
        {
          "value": "profile",
          "label": "Read name & profile picture"
        },
        {
          "value": "email",
          "label": "Read email address"
        },
        {
          "value": "w_member_social",
          "label": "Post on behalf of member"
        },
        {
          "value": "r_organization_social",
          "label": "Read organization posts"
        },
        {
          "value": "w_organization_social",
          "label": "Post on behalf of organization"
        },
        {
          "value": "rw_organization_admin",
          "label": "Manage organization pages"
        },
        {
          "value": "r_ads",
          "label": "Read ads data"
        },
        {
          "value": "r_ads_reporting",
          "label": "Read ads reporting"
        },
        {
          "value": "rw_ads",
          "label": "Manage ad campaigns"
        },
        {
          "value": "r_basicprofile",
          "label": "Read full profile (headline, positions)"
        },
        {
          "value": "r_liteprofile",
          "label": "Read basic profile (name, photo)"
        }
      ],
      "authorized_uris": ["https://api.linkedin.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
