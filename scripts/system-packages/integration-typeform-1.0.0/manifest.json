{
  "name": "@appstrate/typeform",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Typeform (API)",
  "description": "Online form builder and survey platform",
  "keywords": ["forms", "surveys"],
  "license": "Apache-2.0",
  "icon": "typeform",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://api.typeform.com/oauth/authorize",
      "token_endpoint": "https://api.typeform.com/oauth/token",
      "default_scopes": ["accounts:read", "forms:read", "responses:read", "offline"],
      "token_endpoint_auth_method": "client_secret_post",
      "scope_catalog": [
        {
          "value": "accounts:read",
          "label": "Read account info"
        },
        {
          "value": "forms:read",
          "label": "Read forms"
        },
        {
          "value": "forms:write",
          "label": "Create and edit forms"
        },
        {
          "value": "responses:read",
          "label": "Read form responses"
        },
        {
          "value": "responses:write",
          "label": "Delete responses"
        },
        {
          "value": "workspaces:read",
          "label": "Read workspaces"
        },
        {
          "value": "workspaces:write",
          "label": "Create and edit workspaces"
        },
        {
          "value": "webhooks:read",
          "label": "Read webhooks"
        },
        {
          "value": "webhooks:write",
          "label": "Create and edit webhooks"
        },
        {
          "value": "offline",
          "label": "Enable refresh tokens"
        }
      ],
      "authorized_uris": ["https://api.typeform.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
