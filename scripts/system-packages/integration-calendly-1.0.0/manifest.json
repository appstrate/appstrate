{
  "name": "@appstrate/calendly",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "2.0",
  "display_name": "Calendly (API)",
  "description": "Scheduling and appointment booking platform",
  "keywords": ["calendar", "scheduling"],
  "license": "Apache-2.0",
  "icon": "calendly",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://auth.calendly.com/oauth/authorize",
      "token_endpoint": "https://auth.calendly.com/oauth/token",
      "token_endpoint_auth_method": "client_secret_post",
      "code_challenge_methods_supported": ["S256"],
      "authorized_uris": ["https://api.calendly.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
