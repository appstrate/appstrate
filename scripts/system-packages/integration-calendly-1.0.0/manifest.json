{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/calendly",
  "version": "1.0.0",
  "displayName": "Calendly (API)",
  "description": "Scheduling and appointment booking platform",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "calendly",
  "keywords": ["calendar", "scheduling"],
  "apiCall": {
    "authKey": "primary"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": ["https://api.calendly.com/**"],
      "authorizationUrl": "https://auth.calendly.com/oauth/authorize",
      "tokenUrl": "https://auth.calendly.com/oauth/token",
      "refreshUrl": "https://auth.calendly.com/oauth/token",
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post",
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "access_token"
        }
      }
    }
  }
}
