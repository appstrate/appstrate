{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/convertkit",
  "version": "1.0.0",
  "displayName": "ConvertKit (Kit) (API)",
  "description": "Email marketing platform for creators",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "kit",
  "keywords": ["email-marketing", "marketing"],
  "server": {
    "type": "api_call"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": ["https://api.kit.com/**"],
      "authorizationUrl": "https://app.kit.com/oauth/authorize",
      "tokenUrl": "https://app.kit.com/oauth/token",
      "refreshUrl": "https://app.kit.com/oauth/token",
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post",
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "accessToken"
        }
      }
    }
  }
}
