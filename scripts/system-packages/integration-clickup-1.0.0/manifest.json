{
  "name": "@appstrate/clickup",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "ClickUp (API)",
  "description": "Project management and productivity platform",
  "keywords": ["productivity", "project-management"],
  "license": "Apache-2.0",
  "icon": "clickup",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://app.clickup.com/api",
      "token_endpoint": "https://api.clickup.com/api/v2/oauth/token",
      "token_endpoint_auth_method": "client_secret_post",
      "authorized_uris": ["https://api.clickup.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
