{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/wrike",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Wrike",
  "description": "Collaborative work management platform for teams and enterprises",
  "iconUrl": "https://www.google.com/s2/favicons?domain=wrike.com&sz=128",
  "categories": ["project-management", "collaboration"],
  "docsUrl": "https://developers.wrike.com/overview/",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://login.wrike.com/oauth2/authorize/v4",
      "tokenUrl": "https://login.wrike.com/oauth2/token",
      "refreshUrl": "https://login.wrike.com/oauth2/token",
      "defaultScopes": ["Default"],
      "scopeSeparator": ",",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://www.wrike.com/api/**", "https://*.wrike.com/api/**"],
    "availableScopes": [
      { "value": "Default", "label": "Standard access to tasks, folders, projects" },
      { "value": "wsReadOnly", "label": "Read-only access to workspace" },
      { "value": "wsReadWrite", "label": "Full read-write access to workspace" },
      { "value": "amReadOnlyWorkflow", "label": "Read-only access to workflows" },
      { "value": "amReadWriteWorkflow", "label": "Read-write access to workflows" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Create an API app in Wrike",
        "url": "https://www.wrike.com/frontend/apps/index.html#/api"
      },
      {
        "label": "Configure OAuth2 settings and set the redirect URI"
      },
      {
        "label": "Copy your Client ID and Client Secret"
      }
    ]
  },
  "schemaVersion": "1.1"
}
