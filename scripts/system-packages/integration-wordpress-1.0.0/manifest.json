{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/wordpress",
  "version": "1.0.0",
  "displayName": "WordPress",
  "description": "Content management system — manage posts, pages, media, and users via the REST API",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "wordpress",
  "keywords": ["cms", "content"],
  "apiCall": {},
  "auths": {
    "primary": {
      "type": "custom",
      "required": true,
      "authorizedUris": [],
      "allowAllUris": true,
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "site_url": {
              "type": "string",
              "description": "WordPress site URL (e.g. https://mysite.com)"
            },
            "username": {
              "type": "string",
              "description": "WordPress username"
            },
            "application_password": {
              "type": "string",
              "description": "Application Password (generated in Users → Profile → Application Passwords)"
            }
          },
          "required": ["site_url", "username", "application_password"]
        }
      },
      "delivery": {
        "http": {}
      }
    }
  }
}
