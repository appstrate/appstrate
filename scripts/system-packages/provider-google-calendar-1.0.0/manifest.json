{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/google-calendar",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Google Calendar",
  "description": "Calendar and scheduling service by Google",
  "iconUrl": "googlecalendar",
  "categories": ["calendar", "productivity"],
  "docsUrl": "https://developers.google.com/calendar/api/v3/reference",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "refreshUrl": "https://oauth2.googleapis.com/token",
      "defaultScopes": [
        "https://www.googleapis.com/auth/calendar.readonly"
      ],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post",
      "authorizationParams": {
        "access_type": "offline",
        "prompt": "consent"
      }
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://www.googleapis.com/calendar/*"],
    "availableScopes": [
      { "value": "https://www.googleapis.com/auth/calendar.readonly", "label": "Read-only access to calendars and events" },
      { "value": "https://www.googleapis.com/auth/calendar", "label": "Full calendar access (read & write)" },
      { "value": "https://www.googleapis.com/auth/calendar.events", "label": "Manage events on all calendars" },
      { "value": "https://www.googleapis.com/auth/calendar.events.readonly", "label": "Read events only" },
      { "value": "https://www.googleapis.com/auth/calendar.settings.readonly", "label": "Read calendar settings" },
      { "value": "https://www.googleapis.com/auth/calendar.freebusy", "label": "Read free/busy information" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the authorized redirect URI to: {{callbackUrl}}",
    "steps": [
      { "label": "Enable the Google Calendar API", "url": "https://console.cloud.google.com/apis/library/calendar-json.googleapis.com" },
      { "label": "Configure the OAuth consent screen", "url": "https://console.cloud.google.com/apis/credentials/consent" },
      { "label": "Create OAuth credentials", "url": "https://console.cloud.google.com/apis/credentials" }
    ]
  },
  "schemaVersion": "1.0"
}
