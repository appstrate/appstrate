{
  "name": "@appstrate/loom",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "2.0",
  "display_name": "Loom (API)",
  "description": "Video messaging platform — access video metadata, transcripts, and embed information",
  "keywords": ["video", "communication"],
  "license": "Apache-2.0",
  "icon": "loom",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "authorized_uris": ["https://www.loom.com/**", "https://developer.loom.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Loom Developer API key"
            }
          },
          "required": ["api_key"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.api_key}"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
