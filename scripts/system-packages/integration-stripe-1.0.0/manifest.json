{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/stripe",
  "version": "1.0.0",
  "displayName": "Stripe",
  "description": "Payment processing platform",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "stripe",
  "keywords": ["payments", "finance"],
  "apiCall": {},
  "auths": {
    "primary": {
      "type": "api_key",
      "required": true,
      "authorizedUris": ["https://api.stripe.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Stripe API key (sk_...)"
            }
          },
          "required": ["api_key"]
        }
      },
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "api_key"
        }
      }
    }
  }
}
