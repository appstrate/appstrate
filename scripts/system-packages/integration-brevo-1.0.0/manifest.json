{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/brevo",
  "version": "1.0.0",
  "displayName": "Brevo (API)",
  "description": "Email marketing and CRM platform",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "brevo",
  "keywords": ["email", "marketing", "crm"],
  "server": {
    "type": "api_call"
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "required": true,
      "authorizedUris": ["https://api.brevo.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Brevo API v3 key"
            }
          },
          "required": ["api_key"]
        }
      },
      "delivery": {
        "http": {
          "headerName": "api-key",
          "valueFrom": "api_key"
        }
      }
    }
  }
}
