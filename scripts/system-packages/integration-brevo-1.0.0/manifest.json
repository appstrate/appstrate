{
  "name": "@appstrate/brevo",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Brevo (API)",
  "description": "Email marketing and CRM platform",
  "keywords": ["email", "marketing", "crm"],
  "license": "Apache-2.0",
  "icon": "brevo",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "authorized_uris": ["https://api.brevo.com/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Brevo API v3 key"
            }
          },
          "required": ["api_key"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "api-key",
          "value": "{$credential.api_key}"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
