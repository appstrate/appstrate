{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/convertkit",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "ConvertKit (Kit)",
  "description": "Email marketing platform for creators",
  "iconUrl": "kit",
  "categories": ["email-marketing", "marketing"],
  "docsUrl": "https://developers.kit.com/",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://app.kit.com/oauth/authorize",
      "tokenUrl": "https://app.kit.com/oauth/token",
      "refreshUrl": "https://app.kit.com/oauth/token",
      "defaultScopes": [],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.kit.com/**"],
    "availableScopes": []
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Create a Kit (ConvertKit) OAuth app",
        "url": "https://app.kit.com/account_settings/developer_settings"
      },
      { "label": "Configure the redirect URI" },
      { "label": "Copy your Client ID and Client Secret" }
    ]
  },
  "schemaVersion": "1.1"
}
