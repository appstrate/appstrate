{
  "name": "@appstrate/microsoft-teams",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Microsoft Teams (API)",
  "description": "Team collaboration and messaging platform by Microsoft",
  "keywords": ["messaging", "collaboration"],
  "license": "Apache-2.0",
  "icon": "logos:microsoft-teams",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "token_endpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "default_scopes": [
        "Team.ReadBasic.All",
        "Channel.ReadBasic.All",
        "Chat.Read",
        "User.Read",
        "offline_access"
      ],
      "token_endpoint_auth_method": "client_secret_post",
      "code_challenge_methods_supported": ["S256"],
      "scope_catalog": [
        {
          "value": "Team.ReadBasic.All",
          "label": "Read team names and descriptions"
        },
        {
          "value": "Channel.ReadBasic.All",
          "label": "Read channel names and descriptions"
        },
        {
          "value": "ChannelMessage.Read.All",
          "label": "Read channel messages"
        },
        {
          "value": "Chat.Read",
          "label": "Read user chats"
        },
        {
          "value": "Chat.ReadWrite",
          "label": "Read and write user chats"
        },
        {
          "value": "ChatMessage.Send",
          "label": "Send chat messages"
        },
        {
          "value": "ChannelMessage.Send",
          "label": "Send channel messages"
        },
        {
          "value": "User.Read",
          "label": "Read user profile"
        },
        {
          "value": "User.ReadBasic.All",
          "label": "Read all users' basic info"
        },
        {
          "value": "offline_access",
          "label": "Maintain access (refresh tokens)"
        }
      ],
      "authorized_uris": ["https://graph.microsoft.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
