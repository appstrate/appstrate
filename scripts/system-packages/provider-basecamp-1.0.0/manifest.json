{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/basecamp",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Basecamp",
  "description": "Project management and team communication platform",
  "iconUrl": "basecamp",
  "categories": ["project-management", "collaboration"],
  "docsUrl": "https://github.com/basecamp/bc3-api",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://launchpad.37signals.com/authorization/new",
      "tokenUrl": "https://launchpad.37signals.com/authorization/token",
      "refreshUrl": "https://launchpad.37signals.com/authorization/token",
      "defaultScopes": [],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post",
      "tokenContentType": "application/json",
      "authorizationParams": {
        "type": "web_server"
      }
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://3.basecampapi.com/*", "https://launchpad.37signals.com/*"],
    "availableScopes": []
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Register an application on the 37signals Launchpad",
        "url": "https://launchpad.37signals.com/integrations"
      },
      {
        "label": "Set the redirect URI and configure the application"
      },
      {
        "label": "Copy your Client ID and Client Secret"
      }
    ]
  },
  "schemaVersion": "1.0"
}
