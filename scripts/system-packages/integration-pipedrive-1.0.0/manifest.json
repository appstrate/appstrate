{
  "name": "@appstrate/pipedrive",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Pipedrive (API)",
  "description": "Sales CRM and pipeline management platform",
  "keywords": ["crm", "sales"],
  "license": "Apache-2.0",
  "icon": "https://api.iconify.design/logos/pipedrive.svg",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://oauth.pipedrive.com/oauth/authorize",
      "token_endpoint": "https://oauth.pipedrive.com/oauth/token",
      "default_scopes": ["deals:read", "contacts:read", "users:read"],
      "token_endpoint_auth_method": "client_secret_basic",
      "scope_catalog": [
        {
          "value": "deals:read",
          "label": "Read deals"
        },
        {
          "value": "deals:full",
          "label": "Full access to deals"
        },
        {
          "value": "contacts:read",
          "label": "Read persons and organizations"
        },
        {
          "value": "contacts:full",
          "label": "Full access to persons and organizations"
        },
        {
          "value": "activities:read",
          "label": "Read activities"
        },
        {
          "value": "activities:full",
          "label": "Full access to activities"
        },
        {
          "value": "leads:read",
          "label": "Read leads"
        },
        {
          "value": "leads:full",
          "label": "Full access to leads"
        },
        {
          "value": "products:read",
          "label": "Read products"
        },
        {
          "value": "products:full",
          "label": "Full access to products"
        },
        {
          "value": "users:read",
          "label": "Read user information"
        },
        {
          "value": "mail:read",
          "label": "Read mail"
        },
        {
          "value": "mail:full",
          "label": "Full access to mail"
        },
        {
          "value": "recents:read",
          "label": "Read recent changes"
        },
        {
          "value": "search:read",
          "label": "Search across items"
        },
        {
          "value": "admin",
          "label": "Admin access"
        }
      ],
      "authorized_uris": ["https://api.pipedrive.com/**", "https://*.pipedrive.com/api/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
