{
  "name": "@appstrate/linear",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Linear (API)",
  "description": "Modern issue tracking and project management for software teams",
  "keywords": ["project-management", "issue-tracking", "development"],
  "license": "Apache-2.0",
  "icon": "logos:linear-icon",
  "source": {
    "kind": "none"
  },
  "default_tools": ["api_call"],
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://linear.app/oauth/authorize",
      "token_endpoint": "https://api.linear.app/oauth/token",
      "default_scopes": ["read"],
      "token_endpoint_auth_method": "client_secret_post",
      "code_challenge_methods_supported": ["S256"],
      "scope_catalog": [
        {
          "value": "read",
          "label": "Read access to workspace data"
        },
        {
          "value": "write",
          "label": "Write access to workspace data"
        },
        {
          "value": "issues:create",
          "label": "Create new issues"
        },
        {
          "value": "comments:create",
          "label": "Create issue comments"
        },
        {
          "value": "timeSchedule:write",
          "label": "Manage time schedules"
        },
        {
          "value": "admin",
          "label": "Admin-level access"
        }
      ],
      "authorized_uris": ["https://api.linear.app/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": ","
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
