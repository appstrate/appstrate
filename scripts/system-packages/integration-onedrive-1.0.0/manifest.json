{
  "name": "@appstrate/onedrive",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "OneDrive (API)",
  "description": "Cloud file storage and sharing by Microsoft",
  "keywords": ["storage", "productivity"],
  "license": "Apache-2.0",
  "icon": "logos:microsoft-onedrive",
  "source": {
    "kind": "none"
  },
  "default_tools": ["api_call"],
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "token_endpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "default_scopes": ["Files.Read", "User.Read", "offline_access"],
      "token_endpoint_auth_method": "client_secret_post",
      "code_challenge_methods_supported": ["S256"],
      "scope_catalog": [
        {
          "value": "Files.Read",
          "label": "Read user files"
        },
        {
          "value": "Files.Read.All",
          "label": "Read all files user can access"
        },
        {
          "value": "Files.ReadWrite",
          "label": "Read and write user files"
        },
        {
          "value": "Files.ReadWrite.All",
          "label": "Read and write all files"
        },
        {
          "value": "Sites.Read.All",
          "label": "Read SharePoint sites"
        },
        {
          "value": "Sites.ReadWrite.All",
          "label": "Read and write SharePoint sites"
        },
        {
          "value": "User.Read",
          "label": "Read user profile"
        },
        {
          "value": "offline_access",
          "label": "Maintain access (refresh tokens)"
        }
      ],
      "authorized_uris": ["https://graph.microsoft.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
