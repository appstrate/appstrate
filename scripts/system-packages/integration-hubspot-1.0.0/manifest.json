{
  "name": "@appstrate/hubspot",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "HubSpot (API)",
  "description": "CRM, marketing, and sales platform",
  "keywords": ["crm", "marketing"],
  "license": "Apache-2.0",
  "icon": "logos:hubspot",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://app.hubspot.com/oauth/authorize",
      "token_endpoint": "https://api.hubapi.com/oauth/v1/token",
      "default_scopes": ["crm.objects.contacts.read"],
      "token_endpoint_auth_method": "client_secret_post",
      "scope_catalog": [
        {
          "value": "crm.objects.contacts.read",
          "label": "Read contacts"
        },
        {
          "value": "crm.objects.contacts.write",
          "label": "Write contacts"
        },
        {
          "value": "crm.objects.companies.read",
          "label": "Read companies"
        },
        {
          "value": "crm.objects.companies.write",
          "label": "Write companies"
        },
        {
          "value": "crm.objects.deals.read",
          "label": "Read deals"
        },
        {
          "value": "crm.objects.deals.write",
          "label": "Write deals"
        },
        {
          "value": "content",
          "label": "Content access"
        }
      ],
      "authorized_uris": ["https://api.hubapi.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
