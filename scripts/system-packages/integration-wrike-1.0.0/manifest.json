{
  "name": "@appstrate/wrike",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Wrike (API)",
  "description": "Collaborative work management platform for teams and enterprises",
  "keywords": ["project-management", "collaboration"],
  "license": "Apache-2.0",
  "source": {
    "kind": "none"
  },
  "default_tools": ["api_call"],
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://login.wrike.com/oauth2/authorize/v4",
      "token_endpoint": "https://login.wrike.com/oauth2/token",
      "default_scopes": ["Default"],
      "token_endpoint_auth_method": "client_secret_post",
      "scope_catalog": [
        {
          "value": "Default",
          "label": "Standard access to tasks, folders, projects"
        },
        {
          "value": "wsReadOnly",
          "label": "Read-only access to workspace"
        },
        {
          "value": "wsReadWrite",
          "label": "Full read-write access to workspace"
        },
        {
          "value": "amReadOnlyWorkflow",
          "label": "Read-only access to workflows"
        },
        {
          "value": "amReadWriteWorkflow",
          "label": "Read-write access to workflows"
        }
      ],
      "authorized_uris": ["https://www.wrike.com/api/**", "https://*.wrike.com/api/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": ","
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
