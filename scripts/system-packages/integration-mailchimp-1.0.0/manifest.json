{
  "name": "@appstrate/mailchimp",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "2.0",
  "display_name": "Mailchimp (API)",
  "description": "Email marketing and automation platform",
  "keywords": ["email-marketing", "marketing"],
  "license": "Apache-2.0",
  "icon": "mailchimp",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://login.mailchimp.com/oauth2/authorize",
      "token_endpoint": "https://login.mailchimp.com/oauth2/token",
      "token_endpoint_auth_method": "client_secret_post",
      "authorized_uris": ["https://*.api.mailchimp.com/**", "https://login.mailchimp.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
