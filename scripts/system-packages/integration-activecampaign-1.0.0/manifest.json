{
  "name": "@appstrate/activecampaign",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "2.0",
  "display_name": "ActiveCampaign (API)",
  "description": "Marketing automation and CRM platform — contacts, deals, campaigns, and automations",
  "keywords": ["marketing", "crm"],
  "license": "Apache-2.0",
  "icon": "https://api.iconify.design/logos/active-campaign.svg",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "authorized_uris": ["https://*.api-us1.com/**"],
      "allow_all_uris": true,
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "account_name": {
              "type": "string",
              "description": "Your ActiveCampaign account name (subdomain from yourname.activehosted.com)"
            },
            "api_key": {
              "type": "string",
              "description": "API key from Settings → Developer"
            }
          },
          "required": ["account_name", "api_key"]
        }
      },
      "delivery": {
        "http": {
          "in": "header",
          "name": "Api-Token",
          "value": "{$credential.api_key}"
        }
      },
      "_meta": {
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
