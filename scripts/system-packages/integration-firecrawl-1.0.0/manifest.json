{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/firecrawl",
  "version": "1.0.0",
  "displayName": "Firecrawl (API)",
  "description": "Web scraping and crawling API \u2014 extract clean data from any website",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "https://avatars.githubusercontent.com/u/135057108",
  "keywords": ["web-scraping", "data-extraction", "ai"],
  "apiCall": {
    "authKey": "primary"
  },
  "auths": {
    "primary": {
      "type": "api_key",
      "required": true,
      "authorizedUris": ["https://api.firecrawl.dev/**"],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Firecrawl API key (starts with fc-)"
            }
          },
          "required": ["api_key"]
        }
      },
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "api_key"
        }
      }
    }
  }
}
