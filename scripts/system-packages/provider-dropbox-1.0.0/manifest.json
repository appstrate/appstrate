{
  "$schema": "https://afps.appstrate.dev/schema/v1/provider.schema.json",
  "name": "@appstrate/dropbox",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Dropbox",
  "description": "Cloud file storage, sync, and sharing platform",
  "iconUrl": "dropbox",
  "categories": ["storage", "productivity"],
  "docsUrl": "https://www.dropbox.com/developers/documentation/http/documentation",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://www.dropbox.com/oauth2/authorize",
      "tokenUrl": "https://api.dropboxapi.com/oauth2/token",
      "refreshUrl": "https://api.dropboxapi.com/oauth2/token",
      "defaultScopes": [
        "account_info.read",
        "files.metadata.read",
        "files.content.read"
      ],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post",
      "authorizationParams": {
        "token_access_type": "offline"
      }
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.dropboxapi.com/*", "https://content.dropboxapi.com/*"],
    "availableScopes": [
      { "value": "account_info.read", "label": "Read account info" },
      { "value": "files.metadata.read", "label": "Read file and folder metadata" },
      { "value": "files.metadata.write", "label": "Write file and folder metadata" },
      { "value": "files.content.read", "label": "Read file content" },
      { "value": "files.content.write", "label": "Write file content" },
      { "value": "sharing.read", "label": "Read shared files and folders" },
      { "value": "sharing.write", "label": "Manage shared files and folders" },
      { "value": "file_requests.read", "label": "Read file requests" },
      { "value": "file_requests.write", "label": "Manage file requests" }
    ]
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      { "label": "Create a Dropbox app", "url": "https://www.dropbox.com/developers/apps" },
      { "label": "Configure OAuth redirect URI and permissions" },
      { "label": "Copy your App Key (Client ID) and App Secret (Client Secret)" }
    ]
  },
  "schemaVersion": "1.0"
}
