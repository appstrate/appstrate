{
  "name": "@appstrate/canva",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Canva (API)",
  "description": "Online graphic design and visual content platform",
  "keywords": ["design", "marketing"],
  "license": "Apache-2.0",
  "icon": "simple-icons:canva",
  "source": {
    "kind": "none"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://www.canva.com/api/oauth/authorize",
      "token_endpoint": "https://api.canva.com/rest/v1/oauth/token",
      "default_scopes": ["design:meta:read", "design:content:read", "profile:read"],
      "token_endpoint_auth_method": "client_secret_basic",
      "code_challenge_methods_supported": ["S256"],
      "scope_catalog": [
        {
          "value": "design:meta:read",
          "label": "Read design metadata"
        },
        {
          "value": "design:content:read",
          "label": "Read design content"
        },
        {
          "value": "design:content:write",
          "label": "Write design content"
        },
        {
          "value": "design:permission:read",
          "label": "Read design permissions"
        },
        {
          "value": "design:permission:write",
          "label": "Write design permissions"
        },
        {
          "value": "folder:read",
          "label": "Read folders"
        },
        {
          "value": "folder:write",
          "label": "Write folders"
        },
        {
          "value": "asset:read",
          "label": "Read assets"
        },
        {
          "value": "asset:write",
          "label": "Upload assets"
        },
        {
          "value": "brandtemplate:meta:read",
          "label": "Read brand template metadata"
        },
        {
          "value": "brandtemplate:content:read",
          "label": "Read brand template content"
        },
        {
          "value": "profile:read",
          "label": "Read user profile"
        },
        {
          "value": "comment:read",
          "label": "Read comments"
        },
        {
          "value": "comment:write",
          "label": "Write comments"
        }
      ],
      "authorized_uris": ["https://api.canva.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
