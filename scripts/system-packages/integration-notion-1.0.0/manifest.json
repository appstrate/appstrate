{
  "name": "@appstrate/notion",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Notion (API)",
  "description": "All-in-one workspace for notes and docs",
  "keywords": ["productivity", "documentation"],
  "license": "Apache-2.0",
  "icon": "logos:notion-icon",
  "source": {
    "kind": "none"
  },
  "default_tools": ["api_call"],
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://api.notion.com/v1/oauth/authorize",
      "token_endpoint": "https://api.notion.com/v1/oauth/token",
      "token_endpoint_auth_method": "client_secret_basic",
      "authorized_uris": ["https://api.notion.com/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auths": {
        "primary": {}
      }
    }
  }
}
