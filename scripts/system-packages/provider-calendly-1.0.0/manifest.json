{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/provider.schema.json",
  "name": "@appstrate/calendly",
  "version": "1.0.0",
  "type": "provider",
  "displayName": "Calendly",
  "description": "Scheduling and appointment booking platform",
  "iconUrl": "calendly",
  "categories": ["calendar", "scheduling"],
  "docsUrl": "https://developer.calendly.com/api-docs",
  "definition": {
    "authMode": "oauth2",
    "oauth2": {
      "authorizationUrl": "https://auth.calendly.com/oauth/authorize",
      "tokenUrl": "https://auth.calendly.com/oauth/token",
      "refreshUrl": "https://auth.calendly.com/oauth/token",
      "defaultScopes": [],
      "scopeSeparator": " ",
      "pkceEnabled": true,
      "tokenAuthMethod": "client_secret_post"
    },
    "credentialHeaderName": "Authorization",
    "credentialHeaderPrefix": "Bearer",
    "authorizedUris": ["https://api.calendly.com/**"],
    "availableScopes": []
  },
  "setupGuide": {
    "callbackUrlHint": "Set the redirect URI to: {{callbackUrl}}",
    "steps": [
      {
        "label": "Create a Calendly OAuth application",
        "url": "https://developer.calendly.com/create-a-developer-account"
      },
      { "label": "Configure the redirect URI" },
      { "label": "Copy your Client ID and Client Secret" }
    ]
  },
  "schemaVersion": "1.1"
}
