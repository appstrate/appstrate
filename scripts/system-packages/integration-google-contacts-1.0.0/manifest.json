{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/google-contacts",
  "version": "1.0.0",
  "displayName": "Google Contacts (API)",
  "description": "Contact management service by Google",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "googlecontacts",
  "keywords": ["contacts", "productivity"],
  "server": {
    "type": "api_call"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": ["https://people.googleapis.com/**"],
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "refreshUrl": "https://oauth2.googleapis.com/token",
      "scopes": ["https://www.googleapis.com/auth/contacts.readonly"],
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post",
      "availableScopes": [
        {
          "value": "https://www.googleapis.com/auth/contacts.readonly",
          "label": "Read contacts"
        },
        {
          "value": "https://www.googleapis.com/auth/contacts",
          "label": "Read and write contacts"
        },
        {
          "value": "https://www.googleapis.com/auth/contacts.other.readonly",
          "label": "Read 'Other contacts' (auto-suggested)"
        },
        {
          "value": "https://www.googleapis.com/auth/directory.readonly",
          "label": "Read organization directory (Google Workspace)"
        },
        {
          "value": "https://www.googleapis.com/auth/userinfo.profile",
          "label": "Read user profile info"
        }
      ],
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "accessToken"
        }
      }
    }
  }
}
