{
  "name": "@appstrate/intercom",
  "version": "1.0.0",
  "type": "integration",
  "schema_version": "0.1",
  "display_name": "Intercom (API)",
  "description": "Customer messaging and support platform",
  "keywords": ["customer-support", "messaging"],
  "license": "Apache-2.0",
  "icon": "intercom",
  "source": {
    "kind": "api",
    "api": {}
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "authorization_endpoint": "https://app.intercom.com/oauth",
      "token_endpoint": "https://api.intercom.io/auth/eagle/token",
      "token_endpoint_auth_method": "client_secret_post",
      "authorized_uris": ["https://api.intercom.io/**"],
      "delivery": {
        "http": {
          "in": "header",
          "name": "Authorization",
          "prefix": "Bearer",
          "value": "{$credential.access_token}"
        }
      },
      "_meta": {
        "dev.appstrate/oauth": {
          "scope_separator": " "
        },
        "dev.appstrate/auth": {
          "required": true
        }
      }
    }
  },
  "_meta": {
    "dev.appstrate/package": {
      "author": "Appstrate"
    },
    "dev.appstrate/api": {
      "auth_key": "primary"
    }
  }
}
