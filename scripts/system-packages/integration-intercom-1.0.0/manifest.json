{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/intercom",
  "version": "1.0.0",
  "displayName": "Intercom (API)",
  "description": "Customer messaging and support platform",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "intercom",
  "keywords": ["customer-support", "messaging"],
  "apiCall": {
    "authKey": "primary"
  },
  "auths": {
    "primary": {
      "type": "oauth2",
      "required": true,
      "authorizedUris": ["https://api.intercom.io/**"],
      "authorizationUrl": "https://app.intercom.com/oauth",
      "tokenUrl": "https://api.intercom.io/auth/eagle/token",
      "scopeSeparator": " ",
      "pkceEnabled": false,
      "tokenAuthMethod": "client_secret_post",
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Bearer",
          "valueFrom": "access_token"
        }
      }
    }
  }
}
