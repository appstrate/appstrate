{
  "$schema": "https://afps.appstrate.dev/packages/schema/v1/integration.schema.json",
  "manifestVersion": "1.1",
  "type": "integration",
  "name": "@appstrate/twilio",
  "version": "1.0.0",
  "displayName": "Twilio",
  "description": "Cloud communications platform for SMS, voice, and messaging",
  "license": "Apache-2.0",
  "author": "Appstrate",
  "icon": "twilio",
  "keywords": ["messaging", "communications"],
  "apiCall": {},
  "auths": {
    "primary": {
      "type": "api_key",
      "required": true,
      "authorizedUris": [
        "https://api.twilio.com/**",
        "https://lookups.twilio.com/**",
        "https://verify.twilio.com/**"
      ],
      "credentials": {
        "schema": {
          "type": "object",
          "properties": {
            "account_sid": {
              "type": "string",
              "description": "Twilio Account SID (starts with AC)"
            },
            "auth_token": {
              "type": "string",
              "description": "Twilio Auth Token"
            }
          },
          "required": ["account_sid", "auth_token"]
        }
      },
      "delivery": {
        "http": {
          "headerName": "Authorization",
          "headerPrefix": "Basic",
          "valueFrom": {
            "template": "{{account_sid}}:{{auth_token}}",
            "encoding": "base64"
          }
        }
      }
    }
  }
}
